-- Function to get all ShopTp baseparts (ShopTp, ShopTp1, ShopTp2)
local function getAllShopTpParts()
	local shopTps = {}
	local map = workspace:FindFirstChild("Map")
	if not map then return shopTps end
	
	local scripted = map:FindFirstChild("Scripted")
	if not scripted then return shopTps end
	
	local barrier = scripted:FindFirstChild("Barrier")
	if not barrier then return shopTps end
	
	-- Find all ShopTp, ShopTp1, ShopTp2
	for _, part in ipairs(barrier:GetChildren()) do
		if part:IsA("BasePart") and string.match(part.Name, "^ShopTp") then
			table.insert(shopTps, part)
		end
	end
	
	return shopTps
end

-- Function to check if any ShopTp has Transparency = 1
local function isAnyShopTpTransparent()
	local shopTps = getAllShopTpParts()
	for _, part in ipairs(shopTps) do
		-- Check if part has Transparency property and it's >= 0.99 (basically invisible)
		local transparency = part.Transparency
		if transparency and transparency >= 0.99 then
			return true
		end
	end
	return false
end

-- Function to create safe spot box
local function createSafeSpot()
	if safeSpot then
		safeSpot:Destroy()
	end
	
	safeSpot = Instance.new("Part")
	safeSpot.Name = "SafeSpotBox"
	safeSpot.Size = Vector3.new(30, 30, 30)
	safeSpot.Transparency = 0.5
	safeSpot.Color = Color3.fromRGB(0, 255, 0)
	safeSpot.Material = Enum.Material.Neon
	safeSpot.Anchored = true
	safeSpot.CanCollide = false
	safeSpot.Parent = workspace
	
	-- Add a subtle highlight effect
	local selectionBox = Instance.new("SelectionBox")
	selectionBox.Adornee = safeSpot
	selectionBox.Color3 = Color3.fromRGB(0, 255, 0)
	selectionBox.LineThickness = 0.1
	selectionBox.Transparency = 0.5
	selectionBox.Parent = safeSpot
	
	return safeSpot
end

-- Function to teleport to safe spot
local function teleportToSafeSpot()
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if hrp and safeSpot then
		local spotPos = safeSpot.Position
		hrp.CFrame = CFrame.new(spotPos.X, spotPos.Y + 2, spotPos.Z)
	end
end

-- Function to get all apple parts (CACHED)
local function getAllApples()
	local currentTime = tick()
	if currentTime - lastAppleUpdate > 0.5 then
		cachedApples = {}
		local map = workspace:FindFirstChild("Map")
		if map then
			for _, obj in ipairs(map:GetDescendants()) do
				if obj:IsA("ProximityPrompt") then
					local part = obj.Parent
					if part and part.Name and string.find(string.lower(part.Name), "apple") then
						table.insert(cachedApples, {part = part, prompt = obj})
					end
				end
			end
		end
		lastAppleUpdate = currentTime
	end
	return cachedApples
end

-- Auto collect loop
local function startAppleLoop()
	appleLoop = task.spawn(function()
		local appleIndex = 1
		
		while appleEnabled do
			pcall(function()
				local apples = getAllApples()
				
				if #apples > 0 then
					local appleData = apples[appleIndex]
					local prompt = appleData.prompt
					local part = appleData.part
					
					if prompt then
						prompt.HoldDuration = 0
					end
					
					local char = player.Character
					local hrp = char and char:FindFirstChild("HumanoidRootPart")
					if hrp and part then
						local applePos = part.Position
						hrp.CFrame = CFrame.new(applePos.X, applePos.Y + 2, applePos.Z)
						task.wait(0.02)
					end
					
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
					task.wait(0.01)
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
					
					appleIndex = appleIndex + 1
					if appleIndex > #apples then
						appleIndex = 1
					end
				end
			end)
			task.wait(0.05)
		end
	end)
end

-- Auto sell loop (only if no ShopTp has Transparency = 1)
local function startSellLoop()
	sellLoop = task.spawn(function()
		while sellEnabled do
			pcall(function()
				-- Check if any ShopTp has Transparency = 1 (means it's hiding time)
				if isAnyShopTpTransparent() then
					-- Don't teleport to ShopTp when transparent
					task.wait(0.1)
					return
				end
				
				local shopTps = getAllShopTpParts()
				
				if #shopTps > 0 then
					local targetShop = shopTps[math.random(1, #shopTps)]
					local char = player.Character
					local hrp = char and char:FindFirstChild("HumanoidRootPart")
					
					if hrp and targetShop then
						local tpPos = targetShop.Position
						local tpSize = targetShop.Size
						
						-- Teleport INSIDE the portal
						hrp.CFrame = CFrame.new(
							tpPos.X,
							tpPos.Y + (tpSize.Y / 2),
							tpPos.Z
						)
						
						task.wait(0.05)
						
						-- Spam E key to activate portal
						for i = 1, 3 do
							VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
							task.wait(0.01)
							VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
							task.wait(0.01)
						end
					end
				end
			end)
			task.wait(0.1)
		end
	end)
end

-- Auto hide loop (monitors transparency and teleports to safe spot)
local function startHideLoop()
	-- Create the safe spot box
	createSafeSpot()
	
	hideLoop = task.spawn(function()
		local wasTransparent = false
		
		while hideEnabled do
			pcall(function()
				local anyTransparent = isAnyShopTpTransparent()
				
				if anyTransparent then
					-- ShopTp is transparent, teleport to safe spot and hide
					if not wasTransparent then
						print("[Apple Farmer] ShopTp detected as transparent! Teleporting to safe spot...")
					end
					teleportToSafeSpot()
				else
					-- ShopTp is not transparent, can leave safe spot
					if wasTransparent then
						print("[Apple Farmer] ShopTp is no longer transparent. You can leave safe spot.")
					end
				end
				
				wasTransparent = anyTransparent
			end)
			task.wait(0.1) -- Check every 0.1 seconds
		end
	end)
end


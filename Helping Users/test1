-- UPDATED: Get the actual window structure
local function getGameWindow()
    local window = pgui:FindFirstChild("Window")
    if not window then return nil end
    local gameField = window:FindFirstChild("Game")
    if not gameField then return nil end
    local fields = gameField:FindFirstChild("Fields")
    if not fields then return nil end
    return fields
end

-- UPDATED: Get your side's Inner container
local function getMyInner()
    local fields = getGameWindow()
    if not fields then return nil end
    local side = fields:FindFirstChild(FORCED_SIDE)
    if not side then return nil end
    return side:FindFirstChild("Inner")
end

-- UPDATED: Get enemy side's Inner container
local function getEnemyInner()
    local fields = getGameWindow()
    if not fields then return nil end
    local enemySideName = FORCED_SIDE == "Left" and "Right" or "Left"
    local side = fields:FindFirstChild(enemySideName)
    if not side then return nil end
    return side:FindFirstChild("Inner")
end

-- UPDATED: Get lanes from Inner
local function getLanes(inner)
    if not inner then return {} end
    local lanes = {}
    for _, child in pairs(inner:GetChildren()) do
        if child.Name:match("Lane%d+") then
            lanes[tonumber(child.Name:sub(5))] = child
        end
    end
    return lanes
end

-- UPDATED: Get keybinds from Labels
local function getKeybindsFromLane(lane)
    local labels = lane:FindFirstChild("Labels")
    if not labels then return nil end
    local keybinds = {}
    for _, label in pairs(labels:GetChildren()) do
        if label:IsA("TextLabel") and label.Text ~= "" then
            insert(keybinds, label.Text)
        end
    end
    return keybinds
end

-- UPDATED: Check if note is death/poison by image ID
local badNoteAssets = {
    "rbxassetid://116778203667435",
    "rbxassetid://116254476280414",
    "rbxassetid://91620137594170",
    "rbxassetid://84581380793886",
    "rbxassetid://74989444694115"
}

local function isBadNote(noteFrame)
    local layeredSprite = noteFrame:FindFirstChild("LayeredSprite")
    if not layeredSprite then return false end
    
    local imageLabel = layeredSprite:FindFirstChild("ImageLabel") or layeredSprite:FindFirstChild("2")
    if not imageLabel or not imageLabel:IsA("ImageLabel") then return false end
    
    for _, badId in ipairs(badNoteAssets) do
        if imageLabel.Image == badId then
            return true
        end
    end
    return false
end

-- UPDATED: Get all active notes from your side only
local function getMyNotes()
    local inner = getMyInner()
    if not inner then return {} end
    
    local notes = {}
    local lanes = getLanes(inner)
    
    for laneNum, lane in pairs(lanes) do
        local notesContainer = lane:FindFirstChild("Notes")
        if notesContainer then
            for _, noteFrame in pairs(notesContainer:GetChildren()) do
                if noteFrame:IsA("Frame") then
                    insert(notes, {
                        frame = noteFrame,
                        lane = laneNum,
                        position = noteFrame.Position.Y.Scale,
                        isBad = isBadNote(noteFrame),
                        isHold = noteFrame.Size ~= UDim2.fromScale(1, 1)
                    })
                end
            end
        end
    end
    
    -- Sort by position (closest to bottom first)
    sort(notes, function(a, b)
        if settings.DownScroll then
            return a.position > b.position
        else
            return a.position < b.position
        end
    end)
    
    return notes
end

-- UPDATED: Get receptor positions
local function getReceptors()
    local inner = getMyInner()
    if not inner then return {} end
    
    local receptors = {}
    local lanes = getLanes(inner)
    
    for laneNum, lane in pairs(lanes) do
        local receptor = lane:FindFirstChild("Receptor")
        if receptor then
            receptors[laneNum] = receptor.Position.Y.Scale
        end
    end
    
    return receptors
end

-- Key press simulation
local ske = vim.SendKeyEvent
local kk = Enum.KeyCode
local keys = {}
local downKeys = {}
local KPS = 0
local kps = {}

local function pressKey(keyName)
    local keyCode = kk:FromName(keyName)
    if not keyCode then return end
    
    if downKeys[keyName] then
        downKeys[keyName] = false
        ske(vim, false, keyCode, false, game)
    end
    
    -- KPS limiting
    kps[keyName] = (kps[keyName] or 0) + 1
    KPS = KPS + 1
    settings.KPS = KPS
    
    ske(vim, true, keyCode, false, game)
    
    task.wait(settings.HoldDuration + (random() - 0.5) * 2 * settings.HoldDurationRandom)
    
    ske(vim, false, keyCode, false, game)
    
    task.wait(0.05) -- Reset KPS after
    kps[keyName] = kps[keyName] - 1
    KPS = KPS - 1
    settings.KPS = KPS
end

-- UPDATED: Main autoplay logic - ONLY hits your notes
local function autoPlay()
    if not settings.AutoPlay then return end
    
    local receptors = getReceptors()
    local notes = getMyNotes()
    
    for _, note in ipairs(notes) do
        if note.isBad then
            -- Skip bad/death/poison notes
            continue
        end
        
        local laneNum = note.lane
        local receptorY = receptors[laneNum]
        
        if receptorY then
            local distance = math.abs(note.position - receptorY)
            local scrollSpeed = settings.ScrollSpeed
            local timeToHit = distance / (scrollSpeed + 0.01)
            
            if timeToHit <= 0.1 then
                -- Get keybind for this lane
                local inner = getMyInner()
                if inner then
                    local lane = inner["Lane" .. laneNum]
                    if lane then
                        local labels = lane:FindFirstChild("Labels")
                        if labels then
                            local keybind = nil
                            for _, label in pairs(labels:GetChildren()) do
                                if label:IsA("TextLabel") and label.Text ~= "" then
                                    keybind = label.Text
                                    break
                                end
                            end
                            if keybind then
                                spawn(pressKey, keybind)
                            end
                        end
                    end
                end
            end
        end
    end
end

-- UPDATED: Main loop
local running = true
local function startLoop()
    while running do
        if settings.AutoPlay then
            autoPlay()
        end
        rse:Wait()
    end
end

-- UPDATED: Side detection override
settings.Side = FORCED_SIDE

-- UPDATED: Get keybinds for display
local function updateKeybinds()
    local inner = getMyInner()
    if not inner then return end
    
    local allKeybinds = {}
    local lanes = getLanes(inner)
    
    for laneNum, lane in pairs(lanes) do
        local keybinds = getKeybindsFromLane(lane)
        if keybinds and #keybinds > 0 then
            allKeybinds[laneNum] = keybinds[1]
        end
    end
    
    settings.Keybinds = allKeybinds
end

-- Periodic updates
spawn(function()
    while running do
        updateKeybinds()
        
        -- Update lane count
        local inner = getMyInner()
        if inner then
            local lanes = getLanes(inner)
            settings.Lanes = #lanes
        end
        
        task.wait(1)
    end
end)

-- Start the autoplayer
spawn(startLoop)

-- FPS counter
local fpsBuffer = {}
local estFps = 0

spawn(function()
    while running do
        local start = tick()
        rse:Wait()
        local delta = tick() - start
        local fps = 1 / delta
        
        insert(fpsBuffer, fps)
        if #fpsBuffer > 60 then remove(fpsBuffer, 1) end
        
        local sum = 0
        for _, v in fpsBuffer do sum = sum + v end
        estFps = sum / #fpsBuffer
        
        settings.FPS = math.round(estFps * 10) / 10
        settings.RenderDelta = delta
    end
end)


-- Variables
local player = game.Players.LocalPlayer
local savedCount = nil
local countLocked = false
local RepressedMemoriesModel = nil

-- Function to find the RepressedMemories model
local function findRepressedMemoriesModel()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and string.find(obj.Name, "RepressedMemories") then
            return obj
        end
    end
    return nil
end

-- Function to check if a character is inside RepressedMemories model
local function isCharacterInRepressedMemories(character)
    if not character then return false end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    if not RepressedMemoriesModel then
        RepressedMemoriesModel = findRepressedMemoriesModel()
    end
    
    if not RepressedMemoriesModel then return false end
    
    -- Get the bounding box of the RepressedMemories model
    local modelCFrame = RepressedMemoriesModel:GetPivot()
    local modelSize = RepressedMemoriesModel:GetExtentsSize()
    
    -- Check if HRP is inside the model's bounding box
    local localPos = hrp.Position - modelCFrame.Position
    local halfSize = modelSize / 2
    
    return math.abs(localPos.X) <= halfSize.X and
           math.abs(localPos.Y) <= halfSize.Y and
           math.abs(localPos.Z) <= halfSize.Z
end

-- Function to count players inside RepressedMemories
local function getPlayerCountInRepressedMemories()
    local count = 0
    
    for _, otherPlayer in pairs(game.Players:GetPlayers()) do
        local character = otherPlayer.Character
        if character and character.Parent and character:FindFirstChild("HumanoidRootPart") then
            if isCharacterInRepressedMemories(character) then
                count = count + 1
            end
        end
    end
    
    return count
end

-- Function to check if local player is in RepressedMemories map
local function isLocalInRepressedMemories()
    local character = player.Character
    if not character then return false end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    if not RepressedMemoriesModel then
        RepressedMemoriesModel = findRepressedMemoriesModel()
    end
    
    if not RepressedMemoriesModel then return false end
    
    -- Get the bounding box of the RepressedMemories model
    local modelCFrame = RepressedMemoriesModel:GetPivot()
    local modelSize = RepressedMemoriesModel:GetExtentsSize()
    
    -- Check if HRP is inside the model's bounding box
    local localPos = hrp.Position - modelCFrame.Position
    local halfSize = modelSize / 2
    
    return math.abs(localPos.X) <= halfSize.X and
           math.abs(localPos.Y) <= halfSize.Y and
           math.abs(localPos.Z) <= halfSize.Z
end

-- Create the paragraph
local playerCountParagraph = Tab:AddParagraph("How many players currently exist in this realm as of when I started asking this question?", "Loading...")

-- Monitor and update
task.spawn(function()
    while true do
        -- Update the RepressedMemoriesModel reference periodically
        if not RepressedMemoriesModel then
            RepressedMemoriesModel = findRepressedMemoriesModel()
        end
        
        if not countLocked then
            if isLocalInRepressedMemories() then
                -- Just entered, save current count of players inside
                savedCount = getPlayerCountInRepressedMemories()
                countLocked = true
                playerCountParagraph:Set(tostring(savedCount))
            else
                -- Show current count of players inside (for debugging/live view)
                local currentCount = getPlayerCountInRepressedMemories()
                playerCountParagraph:Set(tostring(currentCount))
            end
        end
        task.wait(0.5)
    end
end)

-- Optional: Add a reset function in case player leaves and re-enters
local function resetCount()
    countLocked = false
    savedCount = nil
end

-- Reset when player respawns or leaves the area
player.CharacterAdded:Connect(function()
    resetCount()
    -- Wait a bit for character to fully load
    task.wait(1)
    RepressedMemoriesModel = findRepressedMemoriesModel()
end)

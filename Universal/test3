-- Punch Aura Script - Targets Players + Bosses
local Event = game:GetService("ReplicatedStorage")["Remote Events"].SendPacket
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

-- ============ CONFIGURATION ============
local COOLDOWN = 1  -- Default cooldown (will be changed by textbox)
local lastPunchTime = 0
local punchMethod = "Remote"  -- Default method
local isRunning = false

-- ============ BOSS NAMES ============
local BOSS_NAMES = {
    "Cat", "Dog", "Grand Paladin", "Map Chunk", "Mushroom King",
    "Pumpkin Explosion", "Pumpkin Head", "Scarecrow", "The Lord", "Tree Spike", "Tree Lord"
}

-- ============ STATIC VALUES (Remote) ============
local NETWORK_ID = 812471241519
local STATIC_VECTOR3_1 = Vector3.new(1.5, 1.5, 2)
local STATIC_CFRAME = CFrame.new(1.2999999523163, -0.30000001192093, -2.5999999046326, 1, 0, 0, 0, 1, 0, 0, 0, 1)
local STATIC_VECTOR3_2 = Vector3.new(1, 2, 1)
local STATIC_VECTOR3_3 = Vector3.new(0.52847343683243, -2.6894883831119e-07, -0.84894984960556)

-- ============ FIND ALL TARGETS (Players + Bosses) ============
local function getTargets()
    local targets = {}
    
    -- Add players (excluding local player)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local targetPart = character:FindFirstChild("Left Leg") 
                    or character:FindFirstChild("Torso") 
                    or character:FindFirstChild("HumanoidRootPart")
                if targetPart then
                    table.insert(targets, {
                        type = "player",
                        name = player.Name,
                        character = character,
                        part = targetPart,
                        object = character
                    })
                end
            end
        end
    end
    
    -- Add bosses
    for _, bossName in ipairs(BOSS_NAMES) do
        local boss = workspace:FindFirstChild(bossName)
        if boss then
            local targetPart = boss:FindFirstChild("Torso") 
                or boss:FindFirstChild("HumanoidRootPart") 
                or boss:FindFirstChildWhichIsA("BasePart")
            
            if targetPart then
                table.insert(targets, {
                    type = "boss",
                    name = bossName,
                    character = boss,
                    part = targetPart,
                    object = boss
                })
            end
        end
    end
    
    return targets
end

-- ============ REMOTE PUNCH ============
local function punchRemote(targetData)
    local myChar = LocalPlayer.Character
    if not myChar then return false end
    
    local attackerPart = myChar:FindFirstChild("Right Leg") or myChar:FindFirstChild("Torso")
    if not attackerPart then return false end
    
    local targetPart = targetData.part
    local attackerPos = attackerPart.Position
    local targetPos = targetPart.Position
    local distance = (targetPos - attackerPos).Magnitude
    
    Event:FireServer(
        "Use Punch",
        NETWORK_ID,
        targetData.character,
        Vector3.new(attackerPos.X, attackerPos.Y, attackerPos.Z),
        distance,
        STATIC_VECTOR3_1,
        STATIC_CFRAME,
        targetPart,
        STATIC_VECTOR3_2,
        STATIC_VECTOR3_3
    )
    return true
end

-- ============ SIMULATE CLICK PUNCH (VirtualInputManager) ============
local function simulateClick(x, y)
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0) -- Press down
        task.wait(0.02) -- Tiny delay to mimic a real click
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0) -- Release
    end)
end

local function punchSimulate(targetData)
    local myChar = LocalPlayer.Character
    if not myChar then return false end
    
    -- Get camera and target position
    local camera = workspace.CurrentCamera
    if not camera then return false end
    
    local targetPart = targetData.part
    local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
    
    -- If target is off-screen, click center of screen
    local mouse = LocalPlayer:GetMouse()
    if not onScreen then
        simulateClick(mouse.ViewSizeX / 2, mouse.ViewSizeY / 2)
    else
        simulateClick(screenPos.X, screenPos.Y)
    end
    
    return true
end

-- ============ MAIN PUNCH FUNCTION ============
local function punchTarget(targetData)
    if punchMethod == "Remote" then
        return punchRemote(targetData)
    else -- Simulate Click
        return punchSimulate(targetData)
    end
end

-- ============ MAIN LOOP ============
local function punchLoop()
    while isRunning do
        local currentTime = tick()
        if currentTime - lastPunchTime >= COOLDOWN then
            local targets = getTargets()
            
            if #targets > 0 then
                local punched = false
                for _, target in ipairs(targets) do
                    local success = pcall(function()
                        return punchTarget(target)
                    end)
                    if success then
                        punched = true
                    end
                end
                
                if punched then
                    lastPunchTime = currentTime
                    local playerCount = 0
                    local bossCount = 0
                    for _, t in ipairs(targets) do
                        if t.type == "player" then
                            playerCount = playerCount + 1
                        else
                            bossCount = bossCount + 1
                        end
                    end
                    print("✅ Punched " .. playerCount .. " player(s) and " .. bossCount .. " boss(es) (" .. punchMethod .. ")")
                end
            end
        end
        
        task.wait(0.1) -- Check every 0.1 seconds
    end
end

-- ============ START/STOP CONTROLS ============
local function startAura()
    if isRunning then return end
    isRunning = true
    spawn(punchLoop)
    print("✅ Punch aura started! (Method: " .. punchMethod .. " | Cooldown: " .. COOLDOWN .. "s)")
end

local function stopAura()
    isRunning = false
    print("⏹️ Punch aura stopped!")
end


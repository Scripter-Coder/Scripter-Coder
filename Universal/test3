-- ============ AIMBOT TOGGLE (With Character Rotation) ============
local function aimbotLoop()
    while aimbotActive do
        if SelectedPlayer then
            local target = Players:FindFirstChild(SelectedPlayer)
            local myChar = LocalPlayer.Character
            
            if target and target.Character and myChar then
                local targetPart = target.Character:FindFirstChild("HumanoidRootPart") 
                    or target.Character:FindFirstChild("Torso")
                
                local myRoot = myChar:FindFirstChild("HumanoidRootPart")
                
                if targetPart and myRoot then
                    -- Get camera and look at target
                    local camera = workspace.CurrentCamera
                    if camera then
                        camera.CFrame = CFrame.new(camera.CFrame.Position, targetPart.Position)
                    end
                    
                    -- ROTATE CHARACTER TO FACE TARGET
                    local targetPos = targetPart.Position
                    local myPos = myRoot.Position
                    
                    -- Calculate direction to target (ignore Y axis for smoother rotation)
                    local direction = Vector3.new(targetPos.X - myPos.X, 0, targetPos.Z - myPos.Z)
                    
                    if direction.Magnitude > 1 then
                        -- Create CFrame facing the target
                        local lookAtCFrame = CFrame.lookAt(myRoot.Position, targetPos)
                        
                        -- Apply to character's root part
                        myRoot.CFrame = CFrame.new(myRoot.Position, Vector3.new(targetPos.X, myRoot.Position.Y, targetPos.Z))
                    end
                end
            end
        end
        task.wait(0.05) -- Update 20 times per second
    end
end


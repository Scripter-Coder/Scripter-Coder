-- Utility Functions
local function CreateTween(object, properties, duration, style, direction)
    style = style or Enum.EasingStyle.Quad
    direction = direction or Enum.EasingDirection.Out
    local tween = TweenService:Create(object, TweenInfo.new(duration, style, direction), properties)
    return tween
end

-- Custom Animation System
function OrionLib:MakeCustomAnimation(config)
    config = config or {}
    
    local animationData = {
        GameName = config.GameName or "Unknown Game",
        ScriptName = config.ScriptName or "Loading Script",
        MadeBy = config.MadeBy or "Anonymous",
        HideUsername = false,
        HideAvatar = false,
        AnimationComplete = false
    }
    
    self._currentCustomAnimation = animationData
    return animationData
end


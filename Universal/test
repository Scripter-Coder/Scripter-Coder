local function IsFileOpsDisabled()
	local disabledGameIds = {
		110258689672367, -- Doors: Before Hotel+
		10549820578,    -- Doors: April Fools 2023
	}
	
	for _, id in ipairs(disabledGameIds) do
		if game.PlaceId == id then
			return true
		end
	end
	return false
end


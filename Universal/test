			-- Theme Dropdown + Transparency slider + Custom image textbox
			function ElementFunction:AddThemeDropdown(ThemeDropdownConfig)
				ThemeDropdownConfig = ThemeDropdownConfig or {}
				ThemeDropdownConfig.Name = ThemeDropdownConfig.Name or "Theme"

				local themeOptions = {"Default", "Red", "Orange", "Yellow", "Green", "Cyan", "Blue", "Purple", "Pink", "Brown", "Gray", "Black", "White", "Custom"}

				-- Custom image textbox (hidden by default)
				local CustomImageBox = nil
				local customImageShown = false

				local themeDropdown = ElementFunction:AddDropdown({
					Name = ThemeDropdownConfig.Name,
					Options = themeOptions,
					Default = OrionLib.SelectedTheme,
					Callback = function(Value)
						if Value == "Custom" then
							if not customImageShown and CustomImageBox then
								customImageShown = true
								-- Show a hint notification
								OrionLib:MakeNotification({
									Name = "Custom Theme",
									Content = "Paste your rbxassetid:// image ID in the textbox below.",
									Time = 4
								})
							end
						else
							OrionLib.CustomThemeImage = nil
							OrionLib.SelectedTheme = Value
							SetTheme()
						end
					end
				})

				-- Transparency slider
				ElementFunction:AddSlider({
					Name = "Theme Transparency",
					Min = 0,
					Max = 0.9,
					Default = 0,
					Increment = 0.05,
					ValueName = "",
					Callback = function(Value)
						OrionLib.ThemeTransparency = Value
					end
				})

				-- Custom image ID textbox
				CustomImageBox = ElementFunction:AddTextbox({
					Name = "Custom Image ID",
					Default = "",
					PlaceholderText = "rbxassetid://...",
					TextDisappear = false,
					Callback = function(Text)
						if Text ~= "" then
							-- Strip any non-numeric chars after "rbxassetid://"
							local id = Text:match("rbxassetid://(%d+)") or Text:match("(%d+)")
							if id then
								OrionLib.CustomThemeImage = "rbxassetid://" .. id
								OrionLib.SelectedTheme = "Custom"
								SetTheme()
							end
						end
					end
				})

				return themeDropdown
			end

			return ElementFunction
		end


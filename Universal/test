-- ═══════════════════════════════════════════════════════════════════════════
-- HELPER FUNCTIONS
-- ═══════════════════════════════════════════════════════════════════════════

local function CreateRoundedCorner(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius)
    corner.Parent = instance
    return corner
end

local function CreateStroke(instance, thickness, color)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = thickness
    stroke.Color = color
    stroke.Parent = instance
    return stroke
end

local function CreateShadow(parent, size)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "Shadow"
    shadow.Size = size or UDim2.new(1, 30, 1, 30)
    shadow.Position = UDim2.new(0, -15, 0, -15)
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://1316045217"
    shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    shadow.ImageTransparency = 0.6
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(10, 10, 10, 10)
    shadow.ZIndex = -1
    shadow.Parent = parent
    return shadow
end

local function TweenObject(object, properties, duration, style)
    local tweenInfo = TweenInfo.new(duration or 0.2, (style or Enum.EasingStyle.Quad), Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, tweenInfo, properties)
    tween:Play()
    return tween
end

local function ApplyThemeToGui(element, theme)
    if element._ThemeData then
        for _, data in ipairs(element._ThemeData) do
            local property = data.property
            local colorKey = data.colorKey
            if theme[colorKey] then
                element[property] = theme[colorKey]
            end
        end
    end
    
    for _, child in ipairs(element:GetChildren()) do
        ApplyThemeToGui(child, theme)
    end
end


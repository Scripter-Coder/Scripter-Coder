    arrow.Font = Enum.Font.Gotham
    arrow.Parent = self.Button
    
    -- Dropdown List
    self.List = Instance.new("Frame")
    self.List.Size = UDim2.new(1, 0, 0, 0)
    self.List.Position = UDim2.new(0, 0, 0, 32)
    self.List.BackgroundColor3 = ActiveTheme.Secondary
    self.List.BorderSizePixel = 0
    self.List.Visible = false
    self.List.Parent = self.Button
    self.List.ZIndex = 10
    CreateCorner(self.List, 6)
    CreateStroke(self.List, 1, ActiveTheme.Border)
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 2)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Parent = self.List
    
    local items = {}
    
    for _, val in ipairs(self.Values) do
        local item = Instance.new("TextButton")
        item.Size = UDim2.new(1, 0, 0, 30)
        item.BackgroundColor3 = ActiveTheme.Tertiary
        item.BorderSizePixel = 0
        item.Text = tostring(val)
        item.TextColor3 = ActiveTheme.Text
        item.TextSize = 12
        item.Font = Enum.Font.Gotham
        item.TextXAlignment = Enum.TextXAlignment.Left
        item.Parent = self.List
        item.ZIndex = 11
        
        local itemPad = Instance.new("UIPadding")
        itemPad.PaddingLeft = UDim.new(0, 10)
        itemPad.Parent = item
        
        local selected = false
        if self.Multi then
            if self.Selected[val] then
                selected = true
                item.Text = "✓ " .. tostring(val)
                item.TextColor3 = ActiveTheme.Accent
            end
        else
            if self.Selected == val then
                selected = true
                item.TextColor3 = ActiveTheme.Accent
            end
        end
        
        item.MouseButton1Click:Connect(function()
            if self.Multi then
                if self.Selected[val] then
                    self.Selected[val] = nil
                    item.Text = tostring(val)
                    item.TextColor3 = ActiveTheme.Text
                else
                    self.Selected[val] = true
                    item.Text = "✓ " .. tostring(val)
                    item.TextColor3 = ActiveTheme.Accent
                end
                local list = {}
                for v, _ in pairs(self.Selected) do
                    table.insert(list, v)
                end
                self.Button.Text = #list > 0 and table.concat(list, ", ") or "Select..."
            else
                self.Selected = val
                self.Button.Text = tostring(val)
                for _, it in ipairs(items) do
                    it.TextColor3 = ActiveTheme.Text
                    if it.Text == tostring(val) then
                        it.TextColor3 = ActiveTheme.Accent
                    end
                end
                self:Close()
            end
            for _, cb in ipairs(self.Callbacks) do
                cb(self.Selected)
            end
        end)
        
        table.insert(items, item)
    end
    
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        self.List.Size = UDim2.new(1, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
    end)
    task.defer(function()
        self.List.Size = UDim2.new(1, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
    end)
    
    self.Button.MouseButton1Click:Connect(function()
        if self.Open then
            self:Close()
        else
            self:Open()
        end
    end)
    
    self.Open = function()
        if self.Open then return end
        self.Open = true
        self.List.Visible = true
        arrow.Text = "▲"
        Tween(self.List, {Size = UDim2.new(1, 0, 0, self.List.Size.Y.Offset)}, 0.2)
    end
    
    self.Close = function()
        if not self.Open then return end
        self.Open = false
        arrow.Text = "▼"
        Tween(self.List, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
        task.wait(0.2)
        if not self.Open then
            self.List.Visible = false
        end
    end
    
    self.SetValue = function(val)
        if self.Multi then
            if type(val) == "table" then
                self.Selected = val
                local list = {}
                for v, _ in pairs(val) do
                    table.insert(list, v)
                end
                self.Button.Text = #list > 0 and table.concat(list, ", ") or "Select..."
                for _, it in ipairs(items) do
                    local txt = it.Text:gsub("✓ ", "")
                    if val[txt] then
                        it.Text = "✓ " .. txt
                        it.TextColor3 = ActiveTheme.Accent
                    else
                        it.Text = txt
                        it.TextColor3 = ActiveTheme.Text
                    end
                end
            end
        else
            self.Selected = val
            self.Button.Text = tostring(val)
            for _, it in ipairs(items) do
                if it.Text == tostring(val) or it.Text == "✓ " .. tostring(val) then
                    it.TextColor3 = ActiveTheme.Accent
                else
                    it.TextColor3 = ActiveTheme.Text
                end
            end
        end
        for _, cb in ipairs(self.Callbacks) do
            cb(self.Selected)
        end
        return self
    end
    
    self.OnChanged = function(cb)
        table.insert(self.Callbacks, cb)
        return self
    end
    
    self.GetValue = function()
        return self.Selected
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    return self
end


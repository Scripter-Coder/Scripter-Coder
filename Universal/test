    toggleButton.Parent = toggle
    
    local isToggled = config.Default
    
    toggleButton.MouseButton1Click:Connect(function()
        isToggled = not isToggled
        toggleButton.BackgroundColor3 = isToggled and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(50, 50, 50)
        toggleButton.Text = isToggled and "On" or "Off"
        config.Callback(isToggled)
    end)
    
    return toggle
end

-- Add Dropdown (Fixed)
function OrionLib:MakeDropdown(tab, config)
    config = config or {}
    config.Name = config.Name or "Dropdown"
    config.Options = config.Options or {}
    config.Multi = config.Multi or false
    config.Default = config.Default or {}
    config.Callback = config.Callback or function() end
    
    local dropdown = Instance.new("Frame")
    dropdown.Name = config.Name
    dropdown.Size = UDim2.new(1, -10, 0, 80)
    dropdown.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    dropdown.BackgroundTransparency = 0
    dropdown.BorderSizePixel = 0
    dropdown.ClipsDescendants = true
    dropdown.Parent = tab.TabContent
    
    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Size = UDim2.new(1, -10, 0, 25)
    label.Position = UDim2.new(0, 5, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = config.Name
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.Parent = dropdown
    
    local dropdownButton = Instance.new("TextButton")
    dropdownButton.Name = "DropdownButton"
    dropdownButton.Size = UDim2.new(1, -10, 0, 30)
    dropdownButton.Position = UDim2.new(0, 5, 0, 35)
    dropdownButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    dropdownButton.Text = config.Multi and "Select Options" or "Select Option"
    dropdownButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    dropdownButton.TextSize = 13
    dropdownButton.Font = Enum.Font.Gotham
    dropdownButton.BorderSizePixel = 0
    dropdownButton.Parent = dropdown
    
    local optionsFrame = Instance.new("ScrollingFrame")
    optionsFrame.Name = "OptionsFrame"
    optionsFrame.Size = UDim2.new(1, -10, 0, 0)
    optionsFrame.Position = UDim2.new(0, 5, 0, 70)
    optionsFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    optionsFrame.BackgroundTransparency = 0
    optionsFrame.BorderSizePixel = 0
    optionsFrame.ScrollBarThickness = 4
    optionsFrame.Visible = false
    optionsFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    optionsFrame.Parent = dropdown
    
    local optionsLayout = Instance.new("UIListLayout")
    optionsLayout.Name = "OptionsLayout"
    optionsLayout.Padding = UDim.new(0, 2)
    optionsLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optionsLayout.Parent = optionsFrame
    
    local selectedOptions = {}
    local isOpen = false
    
    local function UpdateOptions()
        for _, child in pairs(optionsFrame:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        for i, option in ipairs(config.Options) do
            local optionButton = Instance.new("TextButton")
            optionButton.Name = option
            optionButton.Size = UDim2.new(1, 0, 0, 25)
            optionButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            optionButton.Text = option
            optionButton.TextColor3 = Color3.fromRGB(200, 200, 200)
            optionButton.TextSize = 13
            optionButton.Font = Enum.Font.Gotham
            optionButton.BorderSizePixel = 0
            optionButton.Parent = optionsFrame
            
            if config.Multi then
                local isSelected = false
                for _, selected in ipairs(selectedOptions) do
                    if selected == option then
                        isSelected = true
                        break
                    end
                end
                optionButton.BackgroundColor3 = isSelected and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(35, 35, 35)
                optionButton.TextColor3 = isSelected and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
                
                optionButton.MouseButton1Click:Connect(function()
                    local found = false
                    for i, selected in ipairs(selectedOptions) do
                        if selected == option then
                            table.remove(selectedOptions, i)
                            found = true
                            break
                        end
                    end
                    if not found then
                        table.insert(selectedOptions, option)
                    end
                    
                    optionButton.BackgroundColor3 = found and Color3.fromRGB(35, 35, 35) or Color3.fromRGB(0, 170, 255)
                    optionButton.TextColor3 = found and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(255, 255, 255)
                    
                    if #selectedOptions > 0 then
                        dropdownButton.Text = table.concat(selectedOptions, ", ")
                    else
                        dropdownButton.Text = "Select Options"
                    end
                    
                    config.Callback(selectedOptions)
                end)
            else
                optionButton.MouseButton1Click:Connect(function()
                    selectedOptions = {option}
                    dropdownButton.Text = option
                    config.Callback(option)
                    isOpen = false
                    optionsFrame.Visible = false
                    dropdown.Size = UDim2.new(1, -10, 0, 80)
                end)
            end
        end
        
        optionsLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            optionsFrame.CanvasSize = UDim2.new(0, 0, 0, optionsLayout.AbsoluteContentSize.Y)
        end)
    end
    
    UpdateOptions()
    
    dropdownButton.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        optionsFrame.Visible = isOpen
        
        if isOpen then
            local optionsHeight = math.min(#config.Options * 27, 150)
            optionsFrame.Size = UDim2.new(1, -10, 0, optionsHeight)
            dropdown.Size = UDim2.new(1, -10, 0, 80 + optionsHeight)
        else
            optionsFrame.Size = UDim2.new(1, -10, 0, 0)
            dropdown.Size = UDim2.new(1, -10, 0, 80)
        end
    end)
    
    if config.Default and #config.Default > 0 then
        selectedOptions = config.Default
        if config.Multi then
            dropdownButton.Text = table.concat(selectedOptions, ", ")
        else
            dropdownButton.Text = selectedOptions[1] or "Select Option"
        end
        config.Callback(selectedOptions)
    end
    
    return dropdown
end

-- Add Slider
function OrionLib:MakeSlider(tab, config)
    config = config or {}
    config.Name = config.Name or "Slider"
    config.Min = config.Min or 0
    config.Max = config.Max or 100
    config.Default = config.Default or 50
    config.Callback = config.Callback or function() end
    
    local slider = Instance.new("Frame")
    slider.Name = config.Name
    slider.Size = UDim2.new(1, -10, 0, 50)
    slider.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    slider.BackgroundTransparency = 0
    slider.BorderSizePixel = 0
    slider.Parent = tab.TabContent
    
    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Size = UDim2.new(1, -10, 0, 20)
    label.Position = UDim2.new(0, 5, 0, 2)
    label.BackgroundTransparency = 1
    label.Text = config.Name .. ": " .. config.Default
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.Parent = slider
    
    local sliderBar = Instance.new("Frame")
    sliderBar.Name = "SliderBar"
    sliderBar.Size = UDim2.new(1, -10, 0, 10)
    sliderBar.Position = UDim2.new(0, 5, 0, 30)
    sliderBar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    sliderBar.BackgroundTransparency = 0
    sliderBar.BorderSizePixel = 0
    sliderBar.Parent = slider
    
    local fillBar = Instance.new("Frame")
    fillBar.Name = "FillBar"
    fillBar.Size = UDim2.new((config.Default - config.Min) / (config.Max - config.Min), 0, 1, 0)
    fillBar.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    fillBar.BackgroundTransparency = 0
    fillBar.BorderSizePixel = 0
    fillBar.Parent = sliderBar
    
    local dragging = false
    local currentValue = config.Default
    
    local function UpdateSlider(input)
        local pos = input.Position.X - sliderBar.AbsolutePosition.X
        local clampedPos = math.clamp(pos / sliderBar.AbsoluteSize.X, 0, 1)
        local value = math.round((clampedPos * (config.Max - config.Min)) + config.Min)
        value = math.clamp(value, config.Min, config.Max)
        
        currentValue = value
        fillBar.Size = UDim2.new((value - config.Min) / (config.Max - config.Min), 0, 1, 0)
        label.Text = config.Name .. ": " .. value
        config.Callback(value)
    end
    
    sliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            UpdateSlider(input)
        end
    end)
    
    sliderBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateSlider(input)
        end
    end)
    
    return slider
end

-- Make Notification
function OrionLib:MakeNotification(config)
    config = config or {}
    config.Name = config.Name or "Notification"
    config.Content = config.Content or ""
    config.Image = config.Image or "rbxassetid://4483345998"
    config.Time = config.Time or 5
    
    self._notificationQueue[#self._notificationQueue + 1] = {Type = "Normal", Config = config}
    self:ProcessNotificationQueue()
end

-- Make Confirm Notification
function OrionLib:MakeConfirmNotification(config)
    config = config or {}
    config.Name = config.Name or "Confirmation"
    config.Content = config.Content or ""
    config.Image = config.Image or "rbxassetid://4483345998"
    config.Time = config.Time or 5
    
    self._notificationQueue[#self._notificationQueue + 1] = {Type = "Confirm", Config = config}
    self:ProcessNotificationQueue()
end

-- Process Notification Queue
function OrionLib:ProcessNotificationQueue()
    if self._isNotificationShowing or #self._notificationQueue == 0 then
        return
    end
    
    self._isNotificationShowing = true
    local notification = table.remove(self._notificationQueue, 1)
    
    if notification.Type == "Normal" then
        self:ShowNormalNotification(notification.Config)
    elseif notification.Type == "Confirm" then
        self:ShowConfirmNotification(notification.Config)
    end
end


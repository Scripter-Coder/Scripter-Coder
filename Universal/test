-- NOTIFICATION SYSTEM
-- ═══════════════════════════════════════════════════════════════════════════

local notificationQueue = {}
local showingNotif = false

local function CreateNotif(parent, config)
    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 340, 0, 70)
    notif.Position = UDim2.new(1, 20, 1, -90)
    notif.BackgroundColor3 = ActiveTheme.Secondary
    notif.BackgroundTransparency = 1
    notif.BorderSizePixel = 0
    notif.Parent = parent
    CreateCorner(notif, 8)
    CreateStroke(notif, 1, ActiveTheme.Border)
    
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0, 4, 1, -16)
    bar.Position = UDim2.new(0, 8, 0, 8)
    bar.BackgroundColor3 = ActiveTheme.Accent
    bar.BackgroundTransparency = 1
    bar.BorderSizePixel = 0
    bar.Parent = notif
    CreateCorner(bar, 2)
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -50, 0, 22)
    title.Position = UDim2.new(0, 20, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = config.Title or "Notification"
    title.TextColor3 = ActiveTheme.Text
    title.TextSize = 14
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = notif
    
    local content = Instance.new("TextLabel")
    content.Size = UDim2.new(1, -20, 0, 30)
    content.Position = UDim2.new(0, 20, 0, 32)
    content.BackgroundTransparency = 1
    content.Text = config.Content or ""
    content.TextColor3 = ActiveTheme.TextSecondary
    content.TextSize = 12
    content.Font = Enum.Font.Gotham
    content.TextXAlignment = Enum.TextXAlignment.Left
    content.TextWrapped = true
    content.Parent = notif
    
    local close = Instance.new("TextButton")
    close.Size = UDim2.new(0, 24, 0, 24)
    close.Position = UDim2.new(1, -30, 0, 6)
    close.BackgroundTransparency = 1
    close.Text = "✕"
    close.TextColor3 = ActiveTheme.TextSecondary
    close.TextSize = 14
    close.Font = Enum.Font.Gotham
    close.Parent = notif
    
    close.MouseButton1Click:Connect(function()
        Tween(notif, {BackgroundTransparency = 1, Position = UDim2.new(1, 20, 1, -70)}, 0.2)
        task.wait(0.2)
        notif:Destroy()
        showingNotif = false
        if #notificationQueue > 0 then
            CreateNotif(parent, table.remove(notificationQueue, 1))
        end
        if config.Callback then config.Callback() end
    end)
    
    Tween(notif, {BackgroundTransparency = 0}, 0.3)
    Tween(notif, {Position = UDim2.new(1, -360, 1, -90)}, 0.3)
    Tween(bar, {BackgroundTransparency = 0}, 0.3)
    
    if config.Duration and config.Duration > 0 then
        task.delay(config.Duration, function()
            if notif and notif.Parent then
                close.MouseButton1Click:Fire()
            end
        end)
    end
end

function CustomLibrary:Notify(config)
    if showingNotif then
        table.insert(notificationQueue, config)
    else
        showingNotif = true
        CreateNotif(self.GUI, config)
    end
end


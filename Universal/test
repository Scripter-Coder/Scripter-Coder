    self.Frame = Instance.new("Frame")
    self.Frame.Size = UDim2.new(1, -20, 0, height)
    self.Frame.BackgroundTransparency = 1
    self.Frame.Parent = parent.Content
    
    self.Button = Instance.new("TextButton")
    self.Button.Size = UDim2.new(1, 0, 0, hasDesc and 30 or height)
    self.Button.BackgroundColor3 = ActiveTheme.Secondary
    self.Button.BorderSizePixel = 0
    self.Button.Text = config.Title or "Button"
    self.Button.TextColor3 = ActiveTheme.Text
    self.Button.TextSize = 13
    self.Button.Font = Enum.Font.GothamSemibold
    self.Button.Parent = self.Frame
    CreateCorner(self.Button, 6)
    CreateStroke(self.Button, 1, ActiveTheme.Border)
    
    if hasDesc then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, 0, 0, 16)
        desc.Position = UDim2.new(0, 10, 0, 32)
        desc.BackgroundTransparency = 1
        desc.Text = config.Description
        desc.TextColor3 = ActiveTheme.TextMuted
        desc.TextSize = 10
        desc.Font = Enum.Font.Gotham
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.Parent = self.Frame
    end
    
    self.Button.MouseEnter:Connect(function()
        Tween(self.Button, {BackgroundColor3 = ActiveTheme.Tertiary}, 0.2)
    end)
    
    self.Button.MouseLeave:Connect(function()
        Tween(self.Button, {BackgroundColor3 = ActiveTheme.Secondary}, 0.2)
    end)
    
    self.Button.MouseButton1Click:Connect(function()
        if config.Callback then
            config.Callback()
        end
    end)
    
    self.Callback = config.Callback
    
    return self
end


-- THEME DROPDOWN
-- ═══════════════════════════════════════════════════════════════════════════

function Window:AddThemeDropdown(parent, config)
    local themeNames = {"Dark", "Light", "Dracula"}
    return self:AddDropdown(parent, {
        Title = config.Title or "Theme",
        Values = themeNames,
        Default = "Dark",
        Callback = function(value)
            ActiveTheme = Themes[value]
            CustomLibrary.CurrentTheme = value
            -- Rebuild UI or just update properties (simplified)
            CustomLibrary:Notify({Title = "Theme", Content = "Theme changed to " .. value, Duration = 2})
        end
    })
end


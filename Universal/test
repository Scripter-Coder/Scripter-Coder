        button.TextSize = 14
        button.Font = Enum.Font.Gotham
        button.BorderSizePixel = 0
        button.Parent = buttonContainer
        
        buttonFunctions[button] = buttonCode
    end
    
    for button, func in pairs(buttonFunctions) do
        button.MouseButton1Click:Connect(function()
            local success, err = pcall(func)
            if not success then
                warn("Button callback error: " .. err)
            end
            
            local dismissTween = CreateTween(notification, {Size = UDim2.new(0, 0, 0, 0)}, 0.3)
            dismissTween:Play()
            dismissTween.Completed:Connect(function()
                notification:Destroy()
                self._isNotificationShowing = false
                self:ProcessNotificationQueue()
            end)
        end)
    end
    
    task.wait(config.Time)
    if notification and notification.Parent then
        local dismissTween = CreateTween(notification, {Size = UDim2.new(0, 0, 0, 0)}, 0.3)
        dismissTween:Play()
        dismissTween.Completed:Connect(function()
            notification:Destroy()
            self._isNotificationShowing = false
            self:ProcessNotificationQueue()
        end)
    end
end

return OrionLib

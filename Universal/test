-- THEME DROPDOWN COMPONENT
-- ═══════════════════════════════════════════════════════════════════════════

function Window:AddThemeDropdown(parent, config)
    local themeNames = {}
    for name, _ in pairs(Themes) do
        table.insert(themeNames, name)
    end
    
    return self:AddDropdown(parent, {
        Title = config.Title or "Theme",
        Values = themeNames,
        Default = CustomLibrary.CurrentTheme or ActiveTheme.Name,
        Callback = function(value)
            CustomLibrary:SetTheme(value)
        end
    })
end


						TweenService:Create(DropdownFrame,TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),{Size = MultiDropdown.Toggled and UDim2.new(1, 0, 0, newHeight) or UDim2.new(1, 0, 0, 42)}):Play()
					end
				end)

				MultiDropdown:Refresh(MultiDropdown.Options, false)
				MultiDropdown:Set(MultiDropdown.Values)
				if MultiDropdownConfig.Flag then				
					OrionLib.Flags[MultiDropdownConfig.Flag] = MultiDropdown
				end

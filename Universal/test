function Window:AddSlider(parent, config)
    local self = setmetatable({}, Slider)
    
    self.Min = config.Min or 0
    self.Max = config.Max or 100
    self.Value = config.Default or self.Min
    self.Rounding = config.Rounding or 0
    self.Callbacks = {}
    
    local hasDesc = config.Description ~= nil
    local height = hasDesc and 70 or 55
    
    self.Frame = Instance.new("Frame")
    self.Frame.Size = UDim2.new(1, -20, 0, height)

    function functions:AddThemeDropdown()
        local themes = {"Red", "Orange", "Yellow", "Green", "Cyan", "Blue", "Purple", "Pink", "Brown", "Gray", "Black", "White"}
        
        local function applyTheme(themeName)
            local theme = OrionLib.Themes[themeName]
            if not theme then return end
            
            MainFrame.BackgroundColor3 = theme.Main
            TitleBar.BackgroundColor3 = theme.Second
            TabBar.BackgroundColor3 = theme.Second
            
            for _, tab in pairs(tabs) do
                tab.btn.BackgroundColor3 = theme.Second
            end
            
            OrionLib.CurrentTheme = themeName
        end
        
        return functions:AddDropdown("Theme", themes, OrionLib.CurrentTheme, applyTheme)
    end
    
    function functions:AddThemeTransparency()
        return functions:AddSlider("Theme Transparency", 0, 0.9, OrionLib.Transparency, function(val)
            OrionLib.Transparency = val
            MainFrame.BackgroundTransparency = val
            for _, tab in pairs(tabs) do
                tab.btn.BackgroundTransparency = 0.5 + val
            end
            for _, element in pairs(allElements) do
                if element.frame then
                    element.frame.BackgroundTransparency = 0.5 + val
                end
            end
        end)
    end
    
    return functions
end

-- Set initial theme
local function applyInitialTheme()
    local theme = OrionLib.Themes.Black
    MainFrame.BackgroundColor3 = theme.Main
    TitleBar.BackgroundColor3 = theme.Second
    TabBar.BackgroundColor3 = theme.Second
end
applyInitialTheme()


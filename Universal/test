							if idx then
								table.remove(MultiDropdown.Values, idx)
							else
								table.insert(MultiDropdown.Values, Option)
							end
							local nowSelected = table.find(MultiDropdown.Values, Option) ~= nil
							TweenService:Create(OptionBtn.Checkmark, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {ImageTransparency = nowSelected and 0 or 1}):Play()
							TweenService:Create(OptionBtn.Title, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {TextTransparency = nowSelected and 0 or 0.4}):Play()
							updateDisplay()
							MultiDropdownConfig.Callback(MultiDropdown.Values)
							SaveCfg(game.GameId)
						end)

						MultiDropdown.Buttons[Option] = OptionBtn
					end
				end

				function MultiDropdown:Refresh(Options, Delete)
					if Delete then
						for _, v in pairs(MultiDropdown.Buttons) do v:Destroy() end
						table.clear(MultiDropdown.Options)
						table.clear(MultiDropdown.Buttons)
						MultiDropdown.Values = {}
					end
					MultiDropdown.Options = Options
					AddOptions(MultiDropdown.Options)
					updateDisplay()
				end

				function MultiDropdown:Set(Values)
					MultiDropdown.Values = Values or {}
					for option, btn in pairs(MultiDropdown.Buttons) do
						local sel = table.find(MultiDropdown.Values, option) ~= nil
						TweenService:Create(btn.Checkmark, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {ImageTransparency = sel and 0 or 1}):Play()
						TweenService:Create(btn.Title, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {TextTransparency = sel and 0 or 0.4}):Play()
					end
					updateDisplay()
					MultiDropdownConfig.Callback(MultiDropdown.Values)
				end

				AddConnection(Click.MouseButton1Click, function()
					MultiDropdown.Toggled = not MultiDropdown.Toggled
					DropdownFrame.F.Line.Visible = MultiDropdown.Toggled
					TweenService:Create(DropdownFrame.F.Ico, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Rotation = MultiDropdown.Toggled and 180 or 0}):Play()
					if MultiDropdown.Toggled then
						local contentH = math.min(#MultiDropdown.Options, MaxElements) * 30
						TweenService:Create(DropdownFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
							Size = UDim2.new(1, 0, 0, 38 + contentH + 4)
						}):Play()
					else
						TweenService:Create(DropdownFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
							Size = UDim2.new(1, 0, 0, 38)
						}):Play()
					end
				end)

				MultiDropdown:Refresh(MultiDropdown.Options, false)
				MultiDropdown:Set(MultiDropdown.Values)
				if MultiDropdownConfig.Flag then
					OrionLib.Flags[MultiDropdownConfig.Flag] = MultiDropdown
				end
				return MultiDropdown
			end


									table.remove(MultiDropdown.Values, i)
									found = true
									break
								end
							end
							if not found then
								table.insert(MultiDropdown.Values, Option)
							end
							
							local newSelected = false
							for _, v in pairs(MultiDropdown.Values) do
								if v == Option then
									newSelected = true
									break
								end
							end
							TweenService:Create(OptionBtn.Checkmark, TweenInfo.new(.15, Enum.EasingStyle.Quad), {ImageTransparency = newSelected and 0 or 1}):Play()
							TweenService:Create(OptionBtn.Title, TweenInfo.new(.15, Enum.EasingStyle.Quad), {TextTransparency = newSelected and 0 or 0.4}):Play()
							updateSelectedDisplay()
							MultiDropdownConfig.Callback(MultiDropdown.Values)
							SaveCfg(game.GameId)
						end)

						MultiDropdown.Buttons[Option] = OptionBtn
					end
				end	

				function MultiDropdown:Refresh(Options, Delete)
					if Delete then
						for _,v in pairs(MultiDropdown.Buttons) do
							v:Destroy()
						end    
						table.clear(MultiDropdown.Options)
						table.clear(MultiDropdown.Buttons)
						MultiDropdown.Values = {}
					end
					MultiDropdown.Options = Options
					AddOptions(MultiDropdown.Options)
					updateSelectedDisplay()
				end  

				function MultiDropdown:Set(Values)
					MultiDropdown.Values = Values or {}
					for option, btn in pairs(MultiDropdown.Buttons) do
						local isSelected = false
						for _, v in pairs(MultiDropdown.Values) do
							if v == option then
								isSelected = true
								break
							end
						end
						TweenService:Create(btn.Checkmark, TweenInfo.new(.15, Enum.EasingStyle.Quad), {ImageTransparency = isSelected and 0 or 1}):Play()
						TweenService:Create(btn.Title, TweenInfo.new(.15, Enum.EasingStyle.Quad), {TextTransparency = isSelected and 0 or 0.4}):Play()
					end
					updateSelectedDisplay()
					MultiDropdownConfig.Callback(MultiDropdown.Values)
				end

				AddConnection(Click.MouseButton1Click, function()
					MultiDropdown.Toggled = not MultiDropdown.Toggled
					DropdownFrame.F.Line.Visible = MultiDropdown.Toggled
					TweenService:Create(DropdownFrame.F.Ico,TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),{Rotation = MultiDropdown.Toggled and 180 or 0}):Play()
					if #MultiDropdown.Options > MaxElements then
						TweenService:Create(DropdownFrame,TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),{Size = MultiDropdown.Toggled and UDim2.new(1, 0, 0, 42 + (MaxElements * 34)) or UDim2.new(1, 0, 0, 42)}):Play()
					else

-- Create Main UI
function OrionLib:MakeWindow(config)
    config = config or {}
    config.Title = config.Title or "Orion Hub"
    config.CustomAnimation = config.CustomAnimation or false
    config.HideUsername = config.HideUsername or false
    config.HideAvatar = config.HideAvatar or false
    
    local windowData = {
        Title = config.Title,
        Elements = {},
        Tabs = {},
        CurrentTab = nil,
        ScreenGui = nil,
        MainFrame = nil
    }
    
    if config.CustomAnimation and self._currentCustomAnimation then
        local animationGui = CreateCustomAnimationGUI(self._currentCustomAnimation, function(animationData)
            config.HideUsername = animationData.HideUsername
            config.HideAvatar = animationData.HideAvatar
            BuildMainUI(windowData, config)
        end)
        windowData.AnimationGui = animationGui
    else
        BuildMainUI(windowData, config)
    end
    
    table.insert(self._windows, windowData)
    return windowData
end


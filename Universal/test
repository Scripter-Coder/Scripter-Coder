    if hasDesc then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, -140, 0, 15)
        desc.Position = UDim2.new(0, 0, 0, 20)
        desc.BackgroundTransparency = 1
        desc.Text = config.Description
        desc.TextColor3 = ActiveTheme.TextMuted
        desc.TextSize = 10
        desc.Font = Enum.Font.Gotham
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.Parent = self.Frame
    end
    
    self.KeyBtn = Instance.new("TextButton")
    self.KeyBtn.Size = UDim2.new(0, 120, 0, 32)
    self.KeyBtn.Position = UDim2.new(1, -120, 0.5, -16)
    self.KeyBtn.BackgroundColor3 = ActiveTheme.Secondary
    self.KeyBtn.BorderSizePixel = 0
    self.KeyBtn.Text = self.Key
    self.KeyBtn.TextColor3 = ActiveTheme.Text
    self.KeyBtn.TextSize = 12
    self.KeyBtn.Font = Enum.Font.Gotham
    self.KeyBtn.Parent = self.Frame
    CreateCorner(self.KeyBtn, 6)
    CreateStroke(self.KeyBtn, 1, ActiveTheme.Border)
    
    local function updateState(newState)
        if self.Mode == "Toggle" then
            self.State = newState
            for _, cb in ipairs(self.Callbacks) do
                cb(self.State)
            end
        elseif self.Mode == "Hold" then
            self.State = newState
            for _, cb in ipairs(self.Callbacks) do
                cb(self.State)
            end
        else
            if newState then
                for _, cb in ipairs(self.Callbacks) do
                    cb(true)
                end
            end
        end
    end
    
    local inputConn
    local function startListen()
        self.Listening = true
        self.KeyBtn.Text = "..."
        self.KeyBtn.BackgroundColor3 = ActiveTheme.Accent
        self.KeyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        inputConn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                self.Key = input.KeyCode.Name
                self.KeyBtn.Text = self.Key
                self.Listening = false
                inputConn:Disconnect()
                Tween(self.KeyBtn, {BackgroundColor3 = ActiveTheme.Secondary}, 0.2)
                Tween(self.KeyBtn, {TextColor3 = ActiveTheme.Text}, 0.2)
                for _, cb in ipairs(self.ChangedCallbacks) do
                    cb(self.Key, self.Mode)
                end
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                self.Key = input.UserInputType.Name
                self.KeyBtn.Text = self.Key
                self.Listening = false
                inputConn:Disconnect()
                Tween(self.KeyBtn, {BackgroundColor3 = ActiveTheme.Secondary}, 0.2)
                Tween(self.KeyBtn, {TextColor3 = ActiveTheme.Text}, 0.2)
                for _, cb in ipairs(self.ChangedCallbacks) do
                    cb(self.Key, self.Mode)
                end
            end
        end)
    end
    
    self.KeyBtn.MouseButton1Click:Connect(function()
        if self.Listening then
            if inputConn then inputConn:Disconnect() end
            self.Listening = false
            self.KeyBtn.Text = self.Key
            Tween(self.KeyBtn, {BackgroundColor3 = ActiveTheme.Secondary}, 0.2)
            Tween(self.KeyBtn, {TextColor3 = ActiveTheme.Text}, 0.2)
        else
            startListen()
        end
    end)
    
    local bindConn
    local function setupBind()
        if bindConn then bindConn:Disconnect() end
        if self.Key == "None" then return end
        
        bindConn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            local match = false
            if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == self.Key then
                match = true
            elseif (input.UserInputType == Enum.UserInputType.MouseButton1 and self.Key == "MouseButton1") or
                   (input.UserInputType == Enum.UserInputType.MouseButton2 and self.Key == "MouseButton2") then
                match = true
            end
            if match then
                if self.Mode == "Toggle" then
                    updateState(not self.State)
                elseif self.Mode == "Hold" then
                    updateState(true)
                else
                    updateState(true)
                    task.delay(0.1, function() updateState(false) end)
                end
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input, gp)
            if gp then return end
            if self.Mode == "Hold" then
                local match = false
                if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == self.Key then
                    match = true
                elseif (input.UserInputType == Enum.UserInputType.MouseButton1 and self.Key == "MouseButton1") or
                       (input.UserInputType == Enum.UserInputType.MouseButton2 and self.Key == "MouseButton2") then
                    match = true
                end
                if match then
                    updateState(false)
                end
            end
        end)
    end
    
    self.OnChanged = function(cb)
        table.insert(self.ChangedCallbacks, cb)
        return self
    end
    
    self.OnClick = function(cb)
        table.insert(self.Callbacks, cb)
        return self
    end
    
    self.SetValue = function(key, mode)
        self.Key = key or self.Key
        self.Mode = mode or self.Mode
        self.KeyBtn.Text = self.Key
        setupBind()
        for _, cb in ipairs(self.ChangedCallbacks) do
            cb(self.Key, self.Mode)
        end
        return self
    end
    
    self.GetState = function()
        return self.State
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    if config.ChangedCallback then
        table.insert(self.ChangedCallbacks, config.ChangedCallback)
    end
    
    setupBind()
    
    return self
end


    -- Simple RGB Sliders for demonstration
    local rSlider, gSlider, bSlider
    
    local function updateColor()
        local r = rSlider and rSlider.GetValue() or self.Value.R * 255
        local g = gSlider and gSlider.GetValue() or self.Value.G * 255
        local b = bSlider and bSlider.GetValue() or self.Value.B * 255

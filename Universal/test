        desc.Parent = self.Frame
        
        desc._ThemeData = {
            {property = "TextColor3", colorKey = "TextMuted"}
        }
        RegisterThemedElement(desc, {{property = "TextColor3", colorKey = "TextMuted"}})
    end
    
    -- Slider Track
    self.Track = Instance.new("Frame")
    self.Track.Size = UDim2.new(1, 0, 0, 6)
    self.Track.Position = UDim2.new(0, 0, 0, (config.Description and 50 or 40))
    self.Track.BackgroundColor3 = ActiveTheme.SliderBackground
    self.Track.BorderSizePixel = 0
    self.Track.Parent = self.Frame
    
    self.Track._ThemeData = {
        {property = "BackgroundColor3", colorKey = "SliderBackground"}
    }
    RegisterThemedElement(self.Track, {{property = "BackgroundColor3", colorKey = "SliderBackground"}})
    CreateRoundedCorner(self.Track, 3)
    
    -- Slider Fill
    self.Fill = Instance.new("Frame")
    local fillPercent = (self.Value - self.Min) / (self.Max - self.Min)
    self.Fill.Size = UDim2.new(fillPercent, 0, 1, 0)
    self.Fill.BackgroundColor3 = ActiveTheme.SliderFill
    self.Fill.BorderSizePixel = 0
    self.Fill.Parent = self.Track
    
    self.Fill._ThemeData = {
        {property = "BackgroundColor3", colorKey = "SliderFill"}
    }
    RegisterThemedElement(self.Fill, {{property = "BackgroundColor3", colorKey = "SliderFill"}})
    CreateRoundedCorner(self.Fill, 3)
    
    -- Slider Knob
    self.Knob = Instance.new("Frame")
    self.Knob.Size = UDim2.new(0, 16, 0, 16)
    self.Knob.Position = UDim2.new(fillPercent, -8, 0.5, -8)
    self.Knob.BackgroundColor3 = ActiveTheme.SliderFill
    self.Knob.BorderSizePixel = 0
    self.Knob.Parent = self.Track
    
    self.Knob._ThemeData = {
        {property = "BackgroundColor3", colorKey = "SliderFill"}
    }
    RegisterThemedElement(self.Knob, {{property = "BackgroundColor3", colorKey = "SliderFill"}})
    CreateRoundedCorner(self.Knob, 8)
    
    local dragging = false
    
    local function updateValue(input)
        local trackPos = self.Track.AbsolutePosition
        local trackWidth = self.Track.AbsoluteSize.X
        if trackWidth == 0 then return end
        local mouseX = input.Position.X
        local percent = math.clamp((mouseX - trackPos.X) / trackWidth, 0, 1)
        local newValue = self.Min + (self.Max - self.Min) * percent
        
        if self.Rounding > 0 then
            newValue = math.round(newValue / self.Rounding) * self.Rounding
        end
        
        newValue = math.clamp(newValue, self.Min, self.Max)
        self.Value = newValue
        
        local newPercent = (self.Value - self.Min) / (self.Max - self.Min)
        self.Fill.Size = UDim2.new(newPercent, 0, 1, 0)
        self.Knob.Position = UDim2.new(newPercent, -8, 0.5, -8)
        
        local displayValue = self.Rounding > 0 and math.round(newValue) or newValue
        self.ValueLabel.Text = tostring(displayValue)
        
        for _, callback in ipairs(self.Callbacks) do
            callback(self.Value)
        end
    end
    
    self.Track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateValue(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateValue(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    self.SetValue = function(value)
        local newValue = math.clamp(value, self.Min, self.Max)
        if self.Rounding > 0 then
            newValue = math.round(newValue / self.Rounding) * self.Rounding
        end
        self.Value = newValue
        local newPercent = (self.Value - self.Min) / (self.Max - self.Min)
        self.Fill.Size = UDim2.new(newPercent, 0, 1, 0)
        self.Knob.Position = UDim2.new(newPercent, -8, 0.5, -8)
        self.ValueLabel.Text = tostring(self.Value)
        for _, callback in ipairs(self.Callbacks) do
            callback(self.Value)
        end
        return self
    end
    
    self.OnChanged = function(callback)
        table.insert(self.Callbacks, callback)
        return self
    end
    
    self.GetValue = function()
        return self.Value
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    return self
end


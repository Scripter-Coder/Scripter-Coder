-- Function to create a switch toggle
local function createSwitch(initialValue, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 40, 0, 20)
    frame.BackgroundColor3 = initialValue and Color3.fromRGB(60, 180, 60) or Color3.fromRGB(180, 60, 60)
    frame.BackgroundTransparency = 0
    frame.Parent = nil
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = frame
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = initialValue and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BackgroundTransparency = 0
    knob.Parent = frame
    
    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob
    
    local value = initialValue
    
    local function setValue(newValue)
        value = newValue
        local targetColor = value and Color3.fromRGB(60, 180, 60) or Color3.fromRGB(180, 60, 60)
        local knobPos = value and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        TweenService:Create(frame, TweenInfo.new(0.15), {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(knob, TweenInfo.new(0.15), {Position = knobPos}):Play()
        callback(value)
    end
    
    local btn = Instance.new("ImageButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Parent = frame
    
    btn.MouseButton1Click:Connect(function()
        setValue(not value)
    end)
    
    return frame, setValue
end

-- Create tab function
function OrionLib:CreateTab(name, icon)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1, -10, 0, 35)
    tabBtn.Position = UDim2.new(0, 5, 0, 0)
    tabBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    tabBtn.BackgroundTransparency = 0.5
    tabBtn.Text = "  " .. name
    tabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    tabBtn.TextSize = 14
    tabBtn.Font = Enum.Font.GothamSemibold
    tabBtn.TextXAlignment = Enum.TextXAlignment.Left
    tabBtn.Parent = TabContainer
    
    local tabCorner = Instance.new("UICorner")
    tabCorner.CornerRadius = UDim.new(0, 5)
    tabCorner.Parent = tabBtn
    
    local contentContainer = Instance.new("Frame")
    contentContainer.Size = UDim2.new(1, 0, 1, 0)
    contentContainer.BackgroundTransparency = 1
    contentContainer.Visible = false
    contentContainer.Parent = ContentArea
    
    local contentList = Instance.new("UIListLayout")
    contentList.Padding = UDim.new(0, 8)
    contentList.Parent = contentContainer
    
    tabs[name] = {btn = tabBtn, container = contentContainer, list = contentList}
    
    tabBtn.MouseButton1Click:Connect(function()
        for _, tab in pairs(tabs) do
            tab.btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            tab.btn.TextColor3 = Color3.fromRGB(200, 200, 200)
            tab.container.Visible = false
        end
        tabBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        contentContainer.Visible = true
        currentTab = name
        
        -- Update canvas size
        task.wait()
        ContentArea.CanvasSize = UDim2.new(0, 0, 0, contentList.AbsoluteContentSize.Y + 10)
    end)
    
    if not currentTab then
        tabBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        contentContainer.Visible = true
        currentTab = name
    end
    
    -- Update canvas size when content changes
    contentList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if contentContainer.Visible then
            ContentArea.CanvasSize = UDim2.new(0, 0, 0, contentList.AbsoluteContentSize.Y + 10)
        end
    end)
    
    -- Search functionality
    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local search = SearchBox.Text:lower()
        for _, element in pairs(allElements) do
            if element.tab == name then
                local visible = search == "" or string.find(element.name:lower(), search)
                element.frame.Visible = visible
            end
        end
    end)
    
    local functions = {}
    
    function functions:AddLabel(text)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 0)
        frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        frame.BackgroundTransparency = 0.5
        frame.AutomaticSize = Enum.AutomaticSize.Y
        frame.Parent = contentContainer
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = frame
        
        local label = createWrappedLabel(text, 100)
        label.Position = UDim2.new(0, 10, 0, 10)
        label.Parent = frame
        
        local padding = Instance.new("UIPadding")
        padding.PaddingBottom = UDim.new(0, 10)
        padding.Parent = frame
        
        table.insert(allElements, {tab = name, name = text, frame = frame})
        
        return {Set = function(t) label.Text = t end}
    end
    
    function functions:AddButton(text, callback)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 40)
        frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)

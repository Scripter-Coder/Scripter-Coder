	local function FilterTabs(searchText)
		CurrentTabFilter = searchText:lower()
		
		for _, tabData in pairs(AllTabs) do
			local tabFrame = tabData.Frame
			local tabName = tabData.Name
			
			if searchText == "" then
				tabFrame.Visible = true
			else
				if string.find(tabName:lower(), CurrentTabFilter) then
					tabFrame.Visible = true
				else
					tabFrame.Visible = false
				end
			end
		end
	end

	local function FilterElements(searchText)
		CurrentElementFilter = searchText:lower()
		
		for _, elementData in pairs(AllElements) do
			local elementFrame = elementData.Frame
			local elementName = elementData.Name
			
			if searchText == "" then

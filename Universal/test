            self.Open = true
        end
    end)
    
    self.SetValueRGB = function(color)
        self.Value = color
        self.Preview.BackgroundColor3 = color
        rSlider:SetValue(color.R * 255)
        gSlider:SetValue(color.G * 255)
        bSlider:SetValue(color.B * 255)
        for _, callback in ipairs(self.Callbacks) do
            callback(self.Value, self.Transparency)
        end
        return self
    end
    
    self.SetTransparency = function(trans)
        self.Transparency = math.clamp(trans, 0, 1)
        for _, callback in ipairs(self.Callbacks) do
            callback(self.Value, self.Transparency)
        end
        return self
    end
    
    self.OnChanged = function(callback)
        table.insert(self.Callbacks, callback)
        return self
    end
    
    self.GetValue = function()
        return self.Value
    end
    
    self.GetTransparency = function()
        return self.Transparency
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    return self
end


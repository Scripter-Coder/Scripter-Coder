-- ═══════════════════════════════════════════════════════════════════════════

local Paragraph = {}
Paragraph.__index = Paragraph

function Window:AddParagraph(parent, config)
    local self = setmetatable({}, Paragraph)
    
    self.Frame = Instance.new("Frame")
    self.Frame.Size = UDim2.new(1, -20, 0, 60)
    self.Frame.BackgroundTransparency = 1
    self.Frame.Parent = parent.Content
    
    self.Title = Instance.new("TextLabel")
    self.Title.Size = UDim2.new(1, 0, 0, 20)
    self.Title.BackgroundTransparency = 1
    self.Title.Text = config.Title or "Title"
    self.Title.TextColor3 = ActiveTheme.Accent
    self.Title.TextSize = 14
    self.Title.Font = Enum.Font.GothamBold
    self.Title.TextXAlignment = Enum.TextXAlignment.Left
    self.Title.Parent = self.Frame
    
    self.Content = Instance.new("TextLabel")
    self.Content.Size = UDim2.new(1, 0, 0, 35)
    self.Content.Position = UDim2.new(0, 0, 0, 22)
    self.Content.BackgroundTransparency = 1
    self.Content.Text = config.Content or "Content"
    self.Content.TextColor3 = ActiveTheme.TextSecondary
    self.Content.TextSize = 11
    self.Content.Font = Enum.Font.Gotham
    self.Content.TextXAlignment = Enum.TextXAlignment.Left
    self.Content.TextWrapped = true
    self.Content.Parent = self.Frame
    
    local function updateHeight()
        task.wait()
        if not self.Frame then return end
        local bounds = self.Content.TextBounds
        local lines = math.max(1, math.ceil(bounds.Y / 16))
        local newH = 22 + (lines * 16)
        self.Frame.Size = UDim2.new(1, -20, 0, newH)
        self.Content.Size = UDim2.new(1, 0, 0, lines * 16)
    end
    
    self.Content:GetPropertyChangedSignal("Text"):Connect(updateHeight)
    task.defer(updateHeight)
    
    return self
end

function Paragraph:SetTitle(text)
    self.Title.Text = text
end

function Paragraph:SetContent(text)
    self.Content.Text = text
end


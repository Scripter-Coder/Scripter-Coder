								ImageTransparency = isSelected and 0 or 1,
								Name = "Checkmark"
							}),
							AddThemeObject(SetProps(MakeElement("Label", Option, 13, isSelected and 0 or 0.4), {
								Position = UDim2.new(0, 30, 0, 4),
								Size = UDim2.new(1, -35, 0, 0),

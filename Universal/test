    self.KeyButton.Position = UDim2.new(1, -120, 0.5, -16)
    self.KeyButton.BackgroundColor3 = ActiveTheme.Secondary
    self.KeyButton.BorderSizePixel = 0
    self.KeyButton.Text = self.Key
    self.KeyButton.TextColor3 = ActiveTheme.Text
    self.KeyButton.TextSize = 12
    self.KeyButton.Font = Enum.Font.Gotham
    self.KeyButton.Parent = self.Frame
    
    self.KeyButton._ThemeData = {
        {property = "BackgroundColor3", colorKey = "Secondary"},
        {property = "TextColor3", colorKey = "Text"}
    }
    RegisterThemedElement(self.KeyButton, {
        {property = "BackgroundColor3", colorKey = "Secondary"},
        {property = "TextColor3", colorKey = "Text"}
    })
    CreateRoundedCorner(self.KeyButton, 6)
    CreateStroke(self.KeyButton, 1, ActiveTheme.Border)
    
    if config.Description then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, -140, 0, 15)
        desc.Position = UDim2.new(0, 0, 0, 20)
        desc.BackgroundTransparency = 1
        desc.Text = config.Description
        desc.TextColor3 = ActiveTheme.TextMuted
        desc.TextSize = 10
        desc.Font = Enum.Font.Gotham
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.Parent = self.Frame
        
        desc._ThemeData = {
            {property = "TextColor3", colorKey = "TextMuted"}
        }
        RegisterThemedElement(desc, {{property = "TextColor3", colorKey = "TextMuted"}})
        self.TitleLabel.Size = UDim2.new(1, -140, 0, 20)
    end
    
    local function updateState(newState)
        if self.Mode == "Toggle" then
            self.State = newState
            for _, callback in ipairs(self.Callbacks) do
                callback(self.State)
            end
        elseif self.Mode == "Hold" then
            self.State = newState
            for _, callback in ipairs(self.Callbacks) do
                callback(self.State)
            end
        else
            if newState then
                for _, callback in ipairs(self.Callbacks) do
                    callback(true)
                end
            end
        end
    end
    
    local inputConnection
    local function startListening()
        self.Listening = true
        self.KeyButton.Text = "..."
        self.KeyButton.BackgroundColor3 = ActiveTheme.Accent
        self.KeyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                self.Key = input.KeyCode.Name
                self.KeyButton.Text = self.Key
                self.Listening = false
                inputConnection:Disconnect()
                TweenObject(self.KeyButton, {BackgroundColor3 = ActiveTheme.Secondary}, 0.2)
                TweenObject(self.KeyButton, {TextColor3 = ActiveTheme.Text}, 0.2)
                for _, callback in ipairs(self.ChangedCallbacks) do
                    callback(self.Key, self.Mode)
                end
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                self.Key = input.UserInputType.Name
                self.KeyButton.Text = self.Key
                self.Listening = false
                inputConnection:Disconnect()
                TweenObject(self.KeyButton, {BackgroundColor3 = ActiveTheme.Secondary}, 0.2)
                TweenObject(self.KeyButton, {TextColor3 = ActiveTheme.Text}, 0.2)
                for _, callback in ipairs(self.ChangedCallbacks) do
                    callback(self.Key, self.Mode)
                end
            end
        end)
    end
    
    self.KeyButton.MouseButton1Click:Connect(function()
        if self.Listening then
            if inputConnection then inputConnection:Disconnect() end
            self.Listening = false
            self.KeyButton.Text = self.Key
            TweenObject(self.KeyButton, {BackgroundColor3 = ActiveTheme.Secondary}, 0.2)
            TweenObject(self.KeyButton, {TextColor3 = ActiveTheme.Text}, 0.2)
        else
            startListening()
        end
    end)
    
    -- Keybind listening
    local keybindConnection
    local function setupKeybindListener()
        if keybindConnection then keybindConnection:Disconnect() end
        
        if self.Key ~= "None" then
            keybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if gameProcessed then return end
                
                local keyMatch = false
                if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == self.Key then
                    keyMatch = true
                elseif (input.UserInputType == Enum.UserInputType.MouseButton1 and self.Key == "MouseButton1") or
                       (input.UserInputType == Enum.UserInputType.MouseButton2 and self.Key == "MouseButton2") then
                    keyMatch = true
                end
                
                if keyMatch then
                    if self.Mode == "Toggle" then
                        updateState(not self.State)
                    elseif self.Mode == "Hold" then
                        updateState(true)
                    else
                        updateState(true)
                        task.delay(0.1, function()
                            updateState(false)
                        end)
                    end
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input, gameProcessed)
                if gameProcessed then return end
                if self.Mode == "Hold" then
                    local keyMatch = false
                    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == self.Key then
                        keyMatch = true
                    elseif (input.UserInputType == Enum.UserInputType.MouseButton1 and self.Key == "MouseButton1") or
                           (input.UserInputType == Enum.UserInputType.MouseButton2 and self.Key == "MouseButton2") then
                        keyMatch = true
                    end
                    if keyMatch then
                        updateState(false)
                    end
                end
            end)
        end
    end
    
    self.OnChanged = function(callback)
        table.insert(self.ChangedCallbacks, callback)
        return self
    end
    
    self.OnClick = function(callback)
        table.insert(self.Callbacks, callback)
        return self
    end
    
    self.SetValue = function(key, mode)
        self.Key = key or self.Key
        self.Mode = mode or self.Mode
        self.KeyButton.Text = self.Key
        setupKeybindListener()
        for _, callback in ipairs(self.ChangedCallbacks) do
            callback(self.Key, self.Mode)
        end
        return self
    end
    
    self.GetState = function()
        return self.State
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    if config.ChangedCallback then
        table.insert(self.ChangedCallbacks, config.ChangedCallback)
    end
    
    setupKeybindListener()
    
    return self
end


local NotificationQueue = {}
local IsShowingNotification = false

local function CreateNotificationFrame(parent, config)
    local notification = Instance.new("Frame")
    notification.Name = "Notification"
    notification.Size = UDim2.new(0, 340, 0, 80)
    notification.Position = UDim2.new(1, 20, 1, -100)
    notification.BackgroundColor3 = ActiveTheme.Secondary
    notification.BackgroundTransparency = 1
    notification.BorderSizePixel = 0
    notification.Parent = parent
    
    notification._ThemeData = {
        {property = "BackgroundColor3", colorKey = "Secondary"}
    }
    RegisterThemedElement(notification, {{property = "BackgroundColor3", colorKey = "Secondary"}})
    
    CreateRoundedCorner(notification, 10)
    CreateStroke(notification, 1, ActiveTheme.Border)
    
    -- Accent Bar
    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 4, 1, -16)
    accentBar.Position = UDim2.new(0, 8, 0, 8)
    accentBar.BackgroundColor3 = config.Type == "Error" and ActiveTheme.Danger or (config.Type == "Success" and ActiveTheme.Success or ActiveTheme.Accent)
    accentBar.BackgroundTransparency = 1
    accentBar.BorderSizePixel = 0
    accentBar.Parent = notification
    CreateRoundedCorner(accentBar, 2)
    
    -- Title
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -50, 0, 22)
    titleLabel.Position = UDim2.new(0, 20, 0, 8)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = config.Title or "Notification"
    titleLabel.TextColor3 = ActiveTheme.Text
    titleLabel.TextSize = 14
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = notification
    
    titleLabel._ThemeData = {
        {property = "TextColor3", colorKey = "Text"}
    }
    RegisterThemedElement(titleLabel, {{property = "TextColor3", colorKey = "Text"}})
    
    -- Content
    local contentLabel = Instance.new("TextLabel")
    contentLabel.Size = UDim2.new(1, -20, 0, 35)
    contentLabel.Position = UDim2.new(0, 20, 0, 32)
    contentLabel.BackgroundTransparency = 1
    contentLabel.Text = config.Content or ""
    contentLabel.TextColor3 = ActiveTheme.TextSecondary
    contentLabel.TextSize = 12
    contentLabel.Font = Enum.Font.Gotham
    contentLabel.TextXAlignment = Enum.TextXAlignment.Left
    contentLabel.TextWrapped = true
    contentLabel.Parent = notification
    
    contentLabel._ThemeData = {
        {property = "TextColor3", colorKey = "TextSecondary"}
    }
    RegisterThemedElement(contentLabel, {{property = "TextColor3", colorKey = "TextSecondary"}})
    
    -- Close Button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 24, 0, 24)
    closeBtn.Position = UDim2.new(1, -30, 0, 6)
    closeBtn.BackgroundTransparency = 1
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = ActiveTheme.TextSecondary
    closeBtn.TextSize = 14
    closeBtn.Font = Enum.Font.Gotham
    closeBtn.Parent = notification
    
    closeBtn._ThemeData = {
        {property = "TextColor3", colorKey = "TextSecondary"}
    }
    RegisterThemedElement(closeBtn, {{property = "TextColor3", colorKey = "TextSecondary"}})
    
    closeBtn.MouseEnter:Connect(function()
        TweenObject(closeBtn, {TextColor3 = ActiveTheme.Danger}, 0.1)
    end)
    
    closeBtn.MouseLeave:Connect(function()
        TweenObject(closeBtn, {TextColor3 = ActiveTheme.TextSecondary}, 0.1)
    end)
    
    closeBtn.MouseButton1Click:Connect(function()
        TweenObject(notification, {BackgroundTransparency = 1, Position = UDim2.new(1, 20, 1, -80)}, 0.2)
        task.wait(0.2)
        notification:Destroy()
        IsShowingNotification = false
        if #NotificationQueue > 0 then
            local next = table.remove(NotificationQueue, 1)
            CreateNotificationFrame(parent, next)
        end
        if config.Callback then config.Callback() end
    end)
    
    -- Animate In
    TweenObject(notification, {BackgroundTransparency = 0}, 0.3)
    TweenObject(notification, {Position = UDim2.new(1, -360, 1, -100)}, 0.3)
    TweenObject(accentBar, {BackgroundTransparency = 0}, 0.3)
    
    -- Auto Close
    if config.Duration and config.Duration > 0 then
        task.delay(config.Duration, function()
            if notification and notification.Parent then
                closeBtn.MouseButton1Click:Fire()
            end
        end)
    end
end

function CustomLibrary:Notify(config)
    config.Type = config.Type or "Info"
    config.Duration = config.Duration or 5
    
    if IsShowingNotification then
        table.insert(NotificationQueue, config)
    else
        IsShowingNotification = true
        CreateNotificationFrame(self.GUI, config)
    end
end

-- ═══════════════════════════════════════════════════════════════════════════
-- THEME MANAGER
-- ═══════════════════════════════════════════════════════════════════════════

function CustomLibrary:SetTheme(themeName)
    local newTheme = Themes[themeName]
    if not newTheme then return false end
    
    ActiveTheme = newTheme
    CustomLibrary.CurrentTheme = themeName
    
    for _, item in ipairs(ThemedElements) do
        local element = item.element
        local properties = item.properties
        if element and element.Parent then
            for _, propData in ipairs(properties) do
                if newTheme[propData.colorKey] then
                    element[propData.property] = newTheme[propData.colorKey]
                end
            end
        end
    end
    
    -- Also update all descendants recursively
    if self.GUI then
        ApplyThemeToGui(self.GUI, newTheme)
    end
    
    return true
end

function CustomLibrary:GetCurrentTheme()
    return ActiveTheme.Name
end


        label.Text = title
        label.TextColor3 = ActiveTheme.Text
        label.TextSize = 11
        label.Font = Enum.Font.GothamBold
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = frame
        
        label._ThemeData = {
            {property = "TextColor3", colorKey = "Text"}
        }
        RegisterThemedElement(label, {{property = "TextColor3", colorKey = "Text"}})
        
        local sliderTrack = Instance.new("Frame")
        sliderTrack.Size = UDim2.new(1, -40, 0, 4)
        sliderTrack.Position = UDim2.new(0, 35, 0.5, -2)
        sliderTrack.BackgroundColor3 = ActiveTheme.SliderBackground
        sliderTrack.BorderSizePixel = 0
        sliderTrack.Parent = frame
        
        sliderTrack._ThemeData = {
            {property = "BackgroundColor3", colorKey = "SliderBackground"}
        }
        RegisterThemedElement(sliderTrack, {{property = "BackgroundColor3", colorKey = "SliderBackground"}})
        CreateRoundedCorner(sliderTrack, 2)
        
        local sliderFill = Instance.new("Frame")
        local initialPercent = initial / 255
        sliderFill.Size = UDim2.new(initialPercent, 0, 1, 0)
        sliderFill.BackgroundColor3 = color
        sliderFill.BorderSizePixel = 0
        sliderFill.Parent = sliderTrack
        CreateRoundedCorner(sliderFill, 2)
        
        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 10, 0, 10)
        knob.Position = UDim2.new(initialPercent, -5, 0.5, -5)
        knob.BackgroundColor3 = color
        knob.BorderSizePixel = 0
        knob.Parent = sliderTrack
        CreateRoundedCorner(knob, 5)
        
        local value = initial
        local dragging = false
        
        local function updateSlider(input)
            local trackPos = sliderTrack.AbsolutePosition
            local trackWidth = sliderTrack.AbsoluteSize.X
            if trackWidth == 0 then return end
            local mouseX = input.Position.X
            local percent = math.clamp((mouseX - trackPos.X) / trackWidth, 0, 1)
            value = math.floor(percent * 255)
            sliderFill.Size = UDim2.new(percent, 0, 1, 0)
            knob.Position = UDim2.new(percent, -5, 0.5, -5)
            updateColor()
        end
        
        sliderTrack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                updateSlider(input)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                updateSlider(input)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        return {
            GetValue = function() return value end,
            SetValue = function(newValue)
                value = math.clamp(newValue, 0, 255)
                local percent = value / 255
                sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                knob.Position = UDim2.new(percent, -5, 0.5, -5)
                updateColor()
            end
        }
    end
    
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 8)
    layout.Parent = self.Popup
    
    rSlider = createColorSlider(self.Popup, "R", Color3.fromRGB(255, 80, 80), self.Value.R * 255)
    gSlider = createColorSlider(self.Popup, "G", Color3.fromRGB(80, 255, 80), self.Value.G * 255)

							Name = "Selected",
							TextXAlignment = Enum.TextXAlignment.Right,
							TextWrapped = true,
							AutomaticSize = Enum.AutomaticSize.Y
						}), "TextDark"),
						AddThemeObject(SetProps(MakeElement("Frame"), {

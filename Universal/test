    toggleButton.Position = UDim2.new(1, -50, 0.5, 0)
    toggleButton.AnchorPoint = Vector2.new(0, 0.5)
    toggleButton.BackgroundColor3 = config.Default and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(50, 50, 50)
    toggleButton.Text = config.Default and "On" or "Off"

    self.Selected = config.Multi and {} or (config.Default or self.Values[1])
    self.Callbacks = {}
    self.Open = false
    
    local frameHeight = config.Description and 55 or 40
    self.Frame = Instance.new("Frame")
    self.Frame.Size = UDim2.new(1, -20, 0, frameHeight)
    self.Frame.BackgroundTransparency = 1
    self.Frame.Parent = parent.Content
    
    self.TitleLabel = Instance.new("TextLabel")
    self.TitleLabel.Size = UDim2.new(1, 0, 0, 18)
    self.TitleLabel.BackgroundTransparency = 1
    self.TitleLabel.Text = config.Title or "Dropdown"
    self.TitleLabel.TextColor3 = ActiveTheme.Text
    self.TitleLabel.TextSize = 13
    self.TitleLabel.Font = Enum.Font.Gotham
    self.TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    self.TitleLabel.Parent = self.Frame
    
    self.TitleLabel._ThemeData = {
        {property = "TextColor3", colorKey = "Text"}
    }
    RegisterThemedElement(self.TitleLabel, {{property = "TextColor3", colorKey = "Text"}})
    
    if config.Description then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, 0, 0, 15)
        desc.Position = UDim2.new(0, 0, 0, 18)
        desc.BackgroundTransparency = 1
        desc.Text = config.Description
        desc.TextColor3 = ActiveTheme.TextMuted
        desc.TextSize = 10
        desc.Font = Enum.Font.Gotham
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.Parent = self.Frame
        
        desc._ThemeData = {
            {property = "TextColor3", colorKey = "TextMuted"}
        }
        RegisterThemedElement(desc, {{property = "TextColor3", colorKey = "TextMuted"}})
    end
    
    -- Dropdown Button
    self.Button = Instance.new("TextButton")
    self.Button.Size = UDim2.new(1, 0, 0, 32)
    self.Button.Position = UDim2.new(0, 0, 0, config.Description and 35 or 20)
    self.Button.BackgroundColor3 = ActiveTheme.Secondary
    self.Button.BorderSizePixel = 0
    self.Button.Text = self.Multi and "Select Options" or tostring(self.Selected)
    self.Button.TextColor3 = ActiveTheme.Text
    self.Button.TextSize = 12
    self.Button.Font = Enum.Font.Gotham
    self.Button.TextXAlignment = Enum.TextXAlignment.Left
    self.Button.Parent = self.Frame
    
    self.Button._ThemeData = {
        {property = "BackgroundColor3", colorKey = "Secondary"},
        {property = "TextColor3", colorKey = "Text"}
    }
    RegisterThemedElement(self.Button, {
        {property = "BackgroundColor3", colorKey = "Secondary"},
        {property = "TextColor3", colorKey = "Text"}
    })
    CreateRoundedCorner(self.Button, 6)
    CreateStroke(self.Button, 1, ActiveTheme.Border)
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 10)
    padding.Parent = self.Button
    
    -- Arrow
    self.Arrow = Instance.new("TextLabel")
    self.Arrow.Size = UDim2.new(0, 30, 1, 0)
    self.Arrow.Position = UDim2.new(1, -30, 0, 0)
    self.Arrow.BackgroundTransparency = 1
    self.Arrow.Text = "▼"
    self.Arrow.TextColor3 = ActiveTheme.TextSecondary
    self.Arrow.TextSize = 12
    self.Arrow.Font = Enum.Font.Gotham
    self.Arrow.Parent = self.Button
    
    self.Arrow._ThemeData = {
        {property = "TextColor3", colorKey = "TextSecondary"}
    }
    RegisterThemedElement(self.Arrow, {{property = "TextColor3", colorKey = "TextSecondary"}})
    
    -- Dropdown List
    self.List = Instance.new("Frame")
    self.List.Size = UDim2.new(1, 0, 0, 0)
    self.List.Position = UDim2.new(0, 0, 0, 32)
    self.List.BackgroundColor3 = ActiveTheme.Secondary
    self.List.BorderSizePixel = 0
    self.List.Visible = false
    self.List.Parent = self.Button
    self.List.ZIndex = 10
    
    self.List._ThemeData = {
        {property = "BackgroundColor3", colorKey = "Secondary"}
    }
    RegisterThemedElement(self.List, {{property = "BackgroundColor3", colorKey = "Secondary"}})
    CreateRoundedCorner(self.List, 6)
    CreateStroke(self.List, 1, ActiveTheme.Border)
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 2)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Parent = self.List
    
    -- Create Items
    local items = {}
    for i, value in ipairs(self.Values) do
        local item = Instance.new("TextButton")
        item.Size = UDim2.new(1, 0, 0, 30)
        item.BackgroundColor3 = ActiveTheme.Tertiary
        item.BorderSizePixel = 0
        item.Text = tostring(value)
        item.TextColor3 = ActiveTheme.Text
        item.TextSize = 12
        item.Font = Enum.Font.Gotham
        item.TextXAlignment = Enum.TextXAlignment.Left
        item.Parent = self.List
        item.ZIndex = 11
        
        item._ThemeData = {
            {property = "BackgroundColor3", colorKey = "Tertiary"},
            {property = "TextColor3", colorKey = "Text"}
        }
        RegisterThemedElement(item, {
            {property = "BackgroundColor3", colorKey = "Tertiary"},
            {property = "TextColor3", colorKey = "Text"}
        })
        
        local itemPadding = Instance.new("UIPadding")
        itemPadding.PaddingLeft = UDim.new(0, 10)
        itemPadding.Parent = item
        
        local isSelected = false
        
        if self.Multi then
            if type(self.Selected) == "table" and self.Selected[value] then
                isSelected = true
                item.Text = "✓ " .. tostring(value)
                item.TextColor3 = ActiveTheme.Accent
            end
        else
            if self.Selected == value then
                isSelected = true
                item.TextColor3 = ActiveTheme.Accent
            end
        end
        
        item.MouseEnter:Connect(function()
            TweenObject(item, {BackgroundColor3 = ActiveTheme.Tertiary:lerp(Color3.fromRGB(255, 255, 255), 0.1)}, 0.1)
        end)
        
        item.MouseLeave:Connect(function()
            TweenObject(item, {BackgroundColor3 = ActiveTheme.Tertiary}, 0.1)
        end)
        
        item.MouseButton1Click:Connect(function()
            if self.Multi then
                if self.Selected[value] then
                    self.Selected[value] = nil
                    item.Text = tostring(value)
                    item.TextColor3 = ActiveTheme.Text
                else
                    self.Selected[value] = true
                    item.Text = "✓ " .. tostring(value)
                    item.TextColor3 = ActiveTheme.Accent
                end
                local selectedList = {}
                for v, _ in pairs(self.Selected) do
                    table.insert(selectedList, v)
                end
                self.Button.Text = #selectedList > 0 and table.concat(selectedList, ", ") or "Select Options"
            else
                self.Selected = value
                self.Button.Text = tostring(value)
                for _, btn in ipairs(items) do
                    btn.TextColor3 = ActiveTheme.Text
                    if btn.Text == tostring(value) then
                        btn.TextColor3 = ActiveTheme.Accent
                    end
                end
                self:Close()
            end
            
            for _, callback in ipairs(self.Callbacks) do
                callback(self.Selected)
            end
        end)
        
        table.insert(items, item)
    end
    
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        self.List.Size = UDim2.new(1, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
    end)
    
    local function updateListHeight()
        self.List.Size = UDim2.new(1, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
    end
    task.defer(updateListHeight)
    
    self.Button.MouseButton1Click:Connect(function()
        if self.Open then
            self:Close()
        else
            self:Open()
        end
    end)
    
    self.Open = function()
        if self.Open then return end
        self.Open = true
        self.List.Visible = true
        self.Arrow.Text = "▲"
        TweenObject(self.List, {Size = UDim2.new(1, 0, 0, self.List.Size.Y.Offset)}, 0.2)
    end
    
    self.Close = function()
        if not self.Open then return end
        self.Open = false
        self.Arrow.Text = "▼"
        TweenObject(self.List, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
        task.wait(0.2)
        if not self.Open then
            self.List.Visible = false
        end
    end
    
    self.SetValue = function(value)
        if self.Multi then
            if type(value) == "table" then
                self.Selected = value
                local selectedList = {}
                for v, _ in pairs(value) do
                    table.insert(selectedList, v)
                end
                self.Button.Text = #selectedList > 0 and table.concat(selectedList, ", ") or "Select Options"
                for _, item in ipairs(items) do
                    local val = item.Text:gsub("✓ ", "")
                    if value[val] then
                        item.Text = "✓ " .. val
                        item.TextColor3 = ActiveTheme.Accent
                    else
                        item.Text = val
                        item.TextColor3 = ActiveTheme.Text
                    end
                end
            end
        else
            self.Selected = value
            self.Button.Text = tostring(value)
            for _, item in ipairs(items) do
                if item.Text == tostring(value) or item.Text == "✓ " .. tostring(value) then
                    item.TextColor3 = ActiveTheme.Accent
                else
                    item.TextColor3 = ActiveTheme.Text
                end
            end
        end
        for _, callback in ipairs(self.Callbacks) do
            callback(self.Selected)
        end
        return self
    end
    
    self.OnChanged = function(callback)
        table.insert(self.Callbacks, callback)
        return self
   
    
    self.GetValue = function()
        return self.Selected
    end
    
    -- Close when clicking outside
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = UserInputService:GetMouseLocation()
            if self.Button and self.Button.Parent then
                local buttonAbsPos = self.Button.AbsolutePosition
                local buttonAbsSize = self.Button.AbsoluteSize
                
                if self.Open and (mousePos.X < buttonAbsPos.X or mousePos.X > buttonAbsPos.X + buttonAbsSize.X or
                    mousePos.Y < buttonAbsPos.Y or mousePos.Y > buttonAbsPos.Y + buttonAbsSize.Y) then
                    self:Close()
                end
            end
        end
    end)
    
    return self
end


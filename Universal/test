    self.Label.TextXAlignment = Enum.TextXAlignment.Left
    self.Label.Parent = self.Frame
    
    self.ValueLabel = Instance.new("TextLabel")
    self.ValueLabel.Size = UDim2.new(0, 70, 0, 20)
    self.ValueLabel.Position = UDim2.new(1, -70, 0, 0)
    self.ValueLabel.BackgroundTransparency = 1
    self.ValueLabel.Text = tostring(self.Value)
    self.ValueLabel.TextColor3 = ActiveTheme.Accent
    self.ValueLabel.TextSize = 12
    self.ValueLabel.Font = Enum.Font.GothamBold
    self.ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
    self.ValueLabel.Parent = self.Frame
    
    if hasDesc then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, 0, 0, 15)
        desc.Position = UDim2.new(0, 0, 0, 20)
        desc.BackgroundTransparency = 1
        desc.Text = config.Description
        desc.TextColor3 = ActiveTheme.TextMuted
        desc.TextSize = 10
        desc.Font = Enum.Font.Gotham
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.Parent = self.Frame
    end
    
    -- Track
    self.Track = Instance.new("Frame")
    self.Track.Size = UDim2.new(1, 0, 0, 6)
    self.Track.Position = UDim2.new(0, 0, 0, hasDesc and 50 or 40)
    self.Track.BackgroundColor3 = ActiveTheme.SliderBg
    self.Track.BorderSizePixel = 0
    self.Track.Parent = self.Frame
    CreateCorner(self.Track, 3)
    
    -- Fill
    local percent = (self.Value - self.Min) / (self.Max - self.Min)
    self.Fill = Instance.new("Frame")
    self.Fill.Size = UDim2.new(percent, 0, 1, 0)
    self.Fill.BackgroundColor3 = ActiveTheme.SliderFill
    self.Fill.BorderSizePixel = 0
    self.Fill.Parent = self.Track
    CreateCorner(self.Fill, 3)
    
    -- Knob
    self.Knob = Instance.new("Frame")
    self.Knob.Size = UDim2.new(0, 16, 0, 16)
    self.Knob.Position = UDim2.new(percent, -8, 0.5, -8)
    self.Knob.BackgroundColor3 = ActiveTheme.SliderFill
    self.Knob.BorderSizePixel = 0
    self.Knob.Parent = self.Track
    CreateCorner(self.Knob, 8)
    
    local dragging = false
    
    local function update(input)
        local trackPos = self.Track.AbsolutePosition
        local trackW = self.Track.AbsoluteSize.X
        if trackW == 0 then return end
        local mouseX = input.Position.X
        local p = math.clamp((mouseX - trackPos.X) / trackW, 0, 1)
        local newVal = self.Min + (self.Max - self.Min) * p
        
        if self.Rounding > 0 then
            newVal = math.round(newVal / self.Rounding) * self.Rounding
        end
        newVal = math.clamp(newVal, self.Min, self.Max)
        self.Value = newVal
        
        local newP = (self.Value - self.Min) / (self.Max - self.Min)
        self.Fill.Size = UDim2.new(newP, 0, 1, 0)
        self.Knob.Position = UDim2.new(newP, -8, 0.5, -8)
        
        local disp = self.Rounding > 0 and math.round(newVal) or newVal
        self.ValueLabel.Text = tostring(disp)
        
        for _, cb in ipairs(self.Callbacks) do
            cb(self.Value)
        end
    end
    
    self.Track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    self.SetValue = function(val)
        local newVal = math.clamp(val, self.Min, self.Max)
        if self.Rounding > 0 then
            newVal = math.round(newVal / self.Rounding) * self.Rounding
        end
        self.Value = newVal
        local newP = (self.Value - self.Min) / (self.Max - self.Min)
        self.Fill.Size = UDim2.new(newP, 0, 1, 0)
        self.Knob.Position = UDim2.new(newP, -8, 0.5, -8)
        self.ValueLabel.Text = tostring(self.Value)
        for _, cb in ipairs(self.Callbacks) do
            cb(self.Value)
        end
        return self
    end
    
    self.OnChanged = function(cb)
        table.insert(self.Callbacks, cb)
        return self
    end
    
    self.GetValue = function()
        return self.Value
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    return self
end


    self.TitleLabel.Parent = self.Frame
    
    self.TitleLabel._ThemeData = {
        {property = "TextColor3", colorKey = "Accent"}
    }
    RegisterThemedElement(self.TitleLabel, {{property = "TextColor3", colorKey = "Accent"}})
    
    self.ContentLabel = Instance.new("TextLabel")
    self.ContentLabel.Size = UDim2.new(1, 0, 0, 35)
    self.ContentLabel.Position = UDim2.new(0, 0, 0, 22)
    self.ContentLabel.BackgroundTransparency = 1
    self.ContentLabel.Text = config.Content or "Content"
    self.ContentLabel.TextColor3 = ActiveTheme.TextSecondary
    self.ContentLabel.TextSize = 11
    self.ContentLabel.Font = Enum.Font.Gotham
    self.ContentLabel.TextXAlignment = Enum.TextXAlignment.Left
    self.ContentLabel.TextWrapped = true
    self.ContentLabel.LineHeight = 1.2
    self.ContentLabel.Parent = self.Frame
    
    self.ContentLabel._ThemeData = {
        {property = "TextColor3", colorKey = "TextSecondary"}
    }
    RegisterThemedElement(self.ContentLabel, {{property = "TextColor3", colorKey = "TextSecondary"}})
    
    -- Auto-adjust height based on content
    local function updateHeight()
        task.wait()
        if not self.Frame then return end
        local textBounds = self.ContentLabel.TextBounds
        local lines = math.max(1, math.ceil(textBounds.Y / 16))
        local newHeight = 22 + (lines * 16)
        self.Frame.Size = UDim2.new(1, -20, 0, newHeight)
        self.ContentLabel.Size = UDim2.new(1, 0, 0, lines * 16)
    end
    
    self.ContentLabel:GetPropertyChangedSignal("Text"):Connect(updateHeight)
    task.defer(updateHeight)
    
    return self
end

function Paragraph:SetTitle(title)
    self.TitleLabel.Text = title
end

function Paragraph:SetContent(content)
    self.ContentLabel.Text = content
end


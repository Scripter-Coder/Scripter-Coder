        {property = "BackgroundColor3", colorKey = "Secondary"},
        {property = "TextColor3", colorKey = "Text"},
        {property = "PlaceholderColor3", colorKey = "TextMuted"}
    })
    CreateRoundedCorner(self.Box, 6)
    CreateStroke(self.Box, 1, ActiveTheme.Border)
    
    local function updateValue(newValue)
        if self.Numeric then
            local num = tonumber(newValue)
            if num then
                self.Value = num
                self.Box.Text = tostring(num)
            else
                self.Box.Text = tostring(self.Value)
                return
            end
        else
            self.Value = newValue
        end
        
        if not self.Finished then
            for _, callback in ipairs(self.Callbacks) do
                callback(self.Value)
            end
        end
    end
    
    self.Box:GetPropertyChangedSignal("Text"):Connect(function()
        if self.Finished then return end
        updateValue(self.Box.Text)
    end)
    
    self.Box.FocusLost:Connect(function(enterPressed)
        if self.Finished and enterPressed then
            updateValue(self.Box.Text)
        end
    end)
    
    self.SetValue = function(value)
        updateValue(value)
        return self
    end
    
    self.OnChanged = function(callback)
        table.insert(self.Callbacks, callback)
        return self
    end
    
    self.GetValue = function()
        return self.Value
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    return self
end


-- TAB
-- ═══════════════════════════════════════════════════════════════════════════

function Window:AddTab(config)
    local tab = {
        Name = config.Title,
        Button = nil,
        Content = nil,
        UIList = nil
    }
    
    -- Tab Button
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 120, 1, 0)
    btn.Position = UDim2.new(0, #self.Tabs * 120, 0, 0)
    btn.BackgroundColor3 = #self.Tabs == 0 and ActiveTheme.TabActive or ActiveTheme.TabInactive
    btn.BorderSizePixel = 0
    btn.Text = config.Title
    btn.TextColor3 = ActiveTheme.Text
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = self.TabContainer
    
    -- Content Frame
    local contentFrame = Instance.new("Frame")
    contentFrame.Size = UDim2.new(1, 0, 1, 0)
    contentFrame.BackgroundTransparency = 1
    contentFrame.Visible = (#self.Tabs == 0)
    contentFrame.Parent = self.ContentContainer
    
    -- Scrolling Frame inside
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -10, 1, -10)
    scroll.Position = UDim2.new(0, 5, 0, 5)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.ScrollBarThickness = 6
    scroll.ScrollBarImageColor3 = ActiveTheme.Accent
    scroll.Parent = contentFrame
    
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 8)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = scroll
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end)
    
    tab.Button = btn
    tab.Content = scroll
    tab.UIList = layout
    
    btn.MouseButton1Click:Connect(function()
        for _, t in pairs(self.Tabs) do
            t.Content.Parent.Visible = false
            t.Button.BackgroundColor3 = ActiveTheme.TabInactive
        end
        contentFrame.Visible = true
        btn.BackgroundColor3 = ActiveTheme.TabActive
        self.CurrentTab = tab
    end)
    
    table.insert(self.Tabs, tab)
    
    return tab
end


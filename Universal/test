        desc.Size = UDim2.new(1, -60, 0, 15)
        desc.Position = UDim2.new(0, 10, 0, 20)
        desc.BackgroundTransparency = 1
        desc.Text = config.Description
        desc.TextColor3 = ActiveTheme.TextMuted
        desc.TextSize = 10
        desc.Font = Enum.Font.Gotham
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.Parent = self.Frame
        
        desc._ThemeData = {
            {property = "TextColor3", colorKey = "TextMuted"}
        }
        RegisterThemedElement(desc, {{property = "TextColor3", colorKey = "TextMuted"}})
    end
    
    -- Toggle Switch
    self.Switch = Instance.new("Frame")
    self.Switch.Size = UDim2.new(0, 40, 0, 22)
    self.Switch.Position = UDim2.new(1, -50, 0.5, -11)
    self.Switch.BackgroundColor3 = self.Value and ActiveTheme.ToggleOn or ActiveTheme.ToggleOff
    self.Switch.BorderSizePixel = 0
    self.Switch.Parent = self.Frame
    
    self.Switch._ThemeData = {
        {property = "BackgroundColor3", colorKey = self.Value and "ToggleOn" or "ToggleOff"}
    }
    RegisterThemedElement(self.Switch, {{property = "BackgroundColor3", colorKey = self.Value and "ToggleOn" or "ToggleOff"}})
    CreateRoundedCorner(self.Switch, 11)
    
    self.Knob = Instance.new("Frame")
    self.Knob.Size = UDim2.new(0, 18, 0, 18)
    self.Knob.Position = self.Value and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
    self.Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    self.Knob.BorderSizePixel = 0
    self.Knob.Parent = self.Switch
    CreateRoundedCorner(self.Knob, 9)
    
    self.Button = Instance.new("TextButton")
    self.Button.Size = UDim2.new(1, 0, 1, 0)
    self.Button.BackgroundTransparency = 1
    self.Button.Text = ""
    self.Button.Parent = self.Frame
    
    local function updateValue(value)
        self.Value = value
        local targetColor = value and ActiveTheme.ToggleOn or ActiveTheme.ToggleOff
        local knobPos = value and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        
        TweenObject(self.Switch, {BackgroundColor3 = targetColor}, 0.2)
        TweenObject(self.Knob, {Position = knobPos}, 0.2)
        
        self.Switch._ThemeData[1].colorKey = value and "ToggleOn" or "ToggleOff"
        
        for _, callback in ipairs(self.Callbacks) do
            callback(value)
        end
    end
    
    self.Button.MouseButton1Click:Connect(function()
        updateValue(not self.Value)
    end)
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    self.SetValue = function(value)
        if type(value) == "boolean" then
            updateValue(value)
        end
        return self
    end
    
    self.OnChanged = function(callback)
        table.insert(self.Callbacks, callback)
        return self
    end
    
    self.GetValue = function()
        return self.Value
    end
    
    return self
end


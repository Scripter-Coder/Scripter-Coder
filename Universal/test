    self.Box.Parent = self.Frame
    CreateCorner(self.Box, 6)
    CreateStroke(self.Box, 1, ActiveTheme.Border)
    
    local function update(val)
        if self.Numeric then
            local num = tonumber(val)
            if num then
                self.Value = num
                self.Box.Text = tostring(num)
            else
                self.Box.Text = tostring(self.Value)
                return
            end
        else
            self.Value = val
        end
        
        if not self.Finished then
            for _, cb in ipairs(self.Callbacks) do
                cb(self.Value)
            end
        end
    end
    
    self.Box:GetPropertyChangedSignal("Text"):Connect(function()
        if self.Finished then return end
        update(self.Box.Text)
    end)
    
    self.Box.FocusLost:Connect(function(enter)
        if self.Finished and enter then
            update(self.Box.Text)
        end
    end)
    
    self.SetValue = function(val)
        update(val)
        return self
    end
    
    self.OnChanged = function(cb)
        table.insert(self.Callbacks, cb)
        return self
    end
    
    self.GetValue = function()
        return self.Value
    end
    
    if config.Callback then
        table.insert(self.Callbacks, config.Callback)
    end
    
    return self
end


	end
end)

-- Dragging functionality with low-executor compatibility
local DraggingInfo = {Dragging = false, MousePos = nil, FramePos = nil}
local ResizingInfo = {Resizing = false, StartSize = nil, StartMousePos = nil}

local function AddDraggingFunctionality(DragPoint, Main)
	DragPoint.InputBegan:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 then
			DraggingInfo.Dragging = true
			DraggingInfo.MousePos = Input.Position
			DraggingInfo.FramePos = Main.Position
		end
	end)
	
	DragPoint.InputEnded:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 then
			DraggingInfo.Dragging = false
		end
	end)
	
	local ResizeHandle = Instance.new("Frame")
	ResizeHandle.Name = "ResizeHandle"
	ResizeHandle.Size = UDim2.new(0, 15, 0, 15)
	ResizeHandle.Position = UDim2.new(1, -15, 1, -15)
	ResizeHandle.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	ResizeHandle.BackgroundTransparency = 0.5
	ResizeHandle.Parent = Main
	
	local ResizeCorner = Instance.new("UICorner")
	ResizeCorner.CornerRadius = UDim.new(0, 3)
	ResizeCorner.Parent = ResizeHandle
	
	ResizeHandle.InputBegan:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 then
			ResizingInfo.Resizing = true
			ResizingInfo.StartSize = Main.Size
			ResizingInfo.StartMousePos = Input.Position
		end
	end)
	
	ResizeHandle.InputEnded:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 then
			ResizingInfo.Resizing = false
			OrionLib.WindowSize = Main.Size
		end
	end)
	
	local lastProcess = 0
	UserInputService.InputChanged:Connect(function(Input)
		if DraggingInfo.Dragging and Input.UserInputType == Enum.UserInputType.MouseMovement then
			local Delta = Input.Position - DraggingInfo.MousePos
			Main.Position = UDim2.new(
				DraggingInfo.FramePos.X.Scale,
				DraggingInfo.FramePos.X.Offset + Delta.X,
				DraggingInfo.FramePos.Y.Scale,
				DraggingInfo.FramePos.Y.Offset + Delta.Y
			)
			OrionLib.WindowPosition = Main.Position
		end
		
		if ResizingInfo.Resizing and Input.UserInputType == Enum.UserInputType.MouseMovement then
			local now = tick()
			if now - lastProcess >= 0.05 then
				lastProcess = now
				local Delta = Input.Position - ResizingInfo.StartMousePos
				local NewWidth = math.max(500, ResizingInfo.StartSize.X.Offset + Delta.X)
				local NewHeight = math.max(350, ResizingInfo.StartSize.Y.Offset + Delta.Y)
				Main.Size = UDim2.new(0, NewWidth, 0, NewHeight)
			end
		end
	end)
end

-- UI Creation helpers
local function Create(Name, Properties, Children)
	local Object = Instance.new(Name)
	for i, v in next, Properties or {} do
		Object[i] = v
	end
	for i, v in next, Children or {} do
		v.Parent = Object
	end
	return Object
end

local function CreateElement(ElementName, ElementFunction)
	OrionLib.Elements[ElementName] = ElementFunction
end

local function MakeElement(ElementName, ...)
	return OrionLib.Elements[ElementName](...)
end

local function SetProps(Element, Props)
	for Property, Value in next, Props do
		Element[Property] = Value
	end
	return Element
end

local function SetChildren(Element, Children)
	for _, Child in next, Children do
		Child.Parent = Element
	end
	return Element
end

local function ReturnProperty(Object)
	if Object:IsA("Frame") or Object:IsA("TextButton") then
		return "BackgroundColor3"
	end
	if Object:IsA("ScrollingFrame") then
		return "ScrollBarImageColor3"
	end
	if Object:IsA("UIStroke") then
		return "Color"
	end
	if Object:IsA("TextLabel") or Object:IsA("TextBox") then
		return "TextColor3"
	end
	if Object:IsA("ImageLabel") or Object:IsA("ImageButton") then
		return "ImageColor3"
	end
end

local function AddThemeObject(Object, Type)
	if not OrionLib.ThemeObjects[Type] then
		OrionLib.ThemeObjects[Type] = {}
	end
	table.insert(OrionLib.ThemeObjects[Type], Object)
	local prop = ReturnProperty(Object)
	if prop and OrionLib.Themes[OrionLib.SelectedTheme] and OrionLib.Themes[OrionLib.SelectedTheme][Type] then
		Object[prop] = OrionLib.Themes[OrionLib.SelectedTheme][Type]
	end
	return Object
end

local function SetTheme()
	for Name, Type in pairs(OrionLib.ThemeObjects) do
		for _, Object in pairs(Type) do
			local prop = ReturnProperty(Object)
			if prop and OrionLib.Themes[OrionLib.SelectedTheme] and OrionLib.Themes[OrionLib.SelectedTheme][Name] then
				Object[prop] = OrionLib.Themes[OrionLib.SelectedTheme][Name]
			end
		end
	end
	for _, frame in pairs(Orion:GetDescendants()) do
		if frame:IsA("Frame") and frame.BackgroundTransparency ~= 1 and not frame:IsA("ScrollingFrame") then
			frame.BackgroundTransparency = OrionLib.ThemeTransparency
		end
	end
end


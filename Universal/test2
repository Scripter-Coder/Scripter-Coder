							TweenService:Create(OptionBtn.Checkmark, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {ImageTransparency = newSelected and 0 or 1}):Play()
							TweenService:Create(OptionBtn.Title, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {TextTransparency = newSelected and 0 or 0.4}):Play()

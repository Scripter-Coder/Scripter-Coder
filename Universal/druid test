-- Variables
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local autoUpgradeEnabled = false
local upgradeConnection = nil

-- Function to upgrade a defense
local function upgradeDefence(defence)
    local args = {
        "Upgrade",
        {
            defence = defence
        }
    }
    ReplicatedStorage.TowerDefenceAssets.TD_Event:FireServer(unpack(args))
end

-- Function to upgrade all defenses
local function upgradeAllDefences()
    local map = workspace.Maps:FindFirstChild("hacedgame146's Map")
    if not map then return end
    
    local defences = map:FindFirstChild("Defences")
    if not defences then return end
    
    for _, child in ipairs(defences:GetChildren()) do
        if child:IsA("Model") then
            upgradeDefence(child)
        end
    end
end

-- Toggle
Tab:AddToggle({
    Name = "Auto Upgrade Defences",
    Default = false,
    Callback = function(Value)
        autoUpgradeEnabled = Value
        
        if autoUpgradeEnabled then
            upgradeConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if autoUpgradeEnabled then
                    upgradeAllDefences()
                end
            end)
            OrionLib:MakeNotification({
                Name = "Auto Upgrade",
                Content = "Started!",
                Time = 2
            })
        else
            if upgradeConnection then
                upgradeConnection:Disconnect()
                upgradeConnection = nil
            end
            OrionLib:MakeNotification({
                Name = "Auto Upgrade",
                Content = "Stopped!",
                Time = 2
            })
        end
    end
})
